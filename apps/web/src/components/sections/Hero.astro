---
interface Props {
  heading: string;
  subheading: string;
  ctaLabel: string;
  ctaHref: string;
}
const { heading, subheading, ctaLabel, ctaHref } = Astro.props;
---
<section style="background: linear-gradient(135deg, #34366a 0%, #4a4d9e 100%); padding: 6rem 8.5vw; text-align: center;">
  <h1 style="color: white; font-size: clamp(2.5rem, 5vw, 5rem); font-weight: 700; margin: 0 0 1rem;">{heading}</h1>
  <p style="color: rgba(255,255,255,0.8); font-size: clamp(1rem, 2vw, 1.5rem); margin: 0 0 2.5rem;">{subheading}</p>
  {ctaLabel && (
    <a href={ctaHref} style="display: inline-block; background: #f97c44; color: white; padding: 1rem 3rem; border-radius: 2rem; font-weight: 700; text-decoration: none; font-size: 1rem;">
      {ctaLabel}
    </a>
  )}
</section>
