---
interface Props {
  bio: string;
  photoUrl: string;
}
const { bio, photoUrl } = Astro.props;
---
<section style="padding: 5rem 8.5vw; background: #f0f5fc;">
  <div style="display: flex; align-items: center; gap: 4rem; max-width: 72rem; margin: 0 auto;">
    {photoUrl ? (
      <img src={photoUrl} alt="Profile photo" style="width: clamp(160px, 20vw, 280px); height: clamp(160px, 20vw, 280px); border-radius: 50%; object-fit: cover; flex-shrink: 0;" />
    ) : null}
    <div>
      <h2 style="color: #34366a; font-weight: 700; font-size: clamp(1.5rem, 3vw, 3rem); margin: 0 0 1rem;">About me</h2>
      <p style="color: #1a1a1a; font-size: clamp(1rem, 1.5vw, 1.25rem); line-height: 1.7; margin: 0;">{bio}</p>
    </div>
  </div>
</section>
