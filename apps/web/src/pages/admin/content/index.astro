---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { db } from "@portify/db";
import { contentItems } from "@portify/db/schema/content";
import { platformMetrics } from "@portify/db/schema/metrics";
import { desc } from "drizzle-orm";

const items = await db
  .select()
  .from(contentItems)
  .orderBy(desc(contentItems.createdAt));

const latestMetrics = await db
  .selectDistinctOn([platformMetrics.contentItemId], {
    contentItemId: platformMetrics.contentItemId,
    views: platformMetrics.views,
    likes: platformMetrics.likes,
    comments: platformMetrics.comments,
    shares: platformMetrics.shares,
  })
  .from(platformMetrics)
  .orderBy(platformMetrics.contentItemId, desc(platformMetrics.fetchedAt));

const metricsMap = new Map(latestMetrics.map(m => [m.contentItemId, m]));

function fmt(n: number): string {
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1).replace(/\.0$/, "") + "M";
  if (n >= 1_000) return (n / 1_000).toFixed(1).replace(/\.0$/, "") + "K";
  return String(n);
}
---

<AdminLayout title="Content">
<div class="px-8 py-10">

  <!-- Page header -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="font-bold" style="font-size:21px;color:var(--text-1);">Content</h1>
      <p class="text-sm mt-0.5" style="color:var(--text-2);">{items.length} item{items.length !== 1 ? "s" : ""}</p>
    </div>
    <a href="/admin/content/new" class="forge-btn forge-btn-primary">+ New</a>
  </div>

  <!-- Filter bar (client-side) + search -->
  <div class="flex items-center justify-between gap-4 mb-4">
    <div class="flex items-center gap-0" id="tab-bar" style="border-bottom:1px solid var(--border);">
      {["All","Published","Draft","Archived"].map((tab, i) => (
        <button
          data-tab={tab.toLowerCase()}
          class="px-4 py-2 text-sm transition-colors"
          style={i === 0
            ? `color:var(--accent);border-bottom:2px solid var(--accent);margin-bottom:-1px;font-weight:500;background:transparent;border-top:none;border-left:none;border-right:none;cursor:pointer;font-family:inherit;`
            : `color:var(--text-2);border-bottom:2px solid transparent;margin-bottom:-1px;background:transparent;border-top:none;border-left:none;border-right:none;cursor:pointer;font-family:inherit;`}
        >
          {tab}
        </button>
      ))}
    </div>

    <!-- Search -->
    <div class="relative">
      <svg class="absolute left-2.5 top-1/2 -translate-y-1/2" width="12" height="12" viewBox="0 0 16 16" fill="none" style="color:var(--text-3);">
        <circle cx="6.5" cy="6.5" r="4.5" stroke="currentColor" stroke-width="1.5"/>
        <path d="M10.5 10.5L14 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <input
        id="search-input"
        type="text"
        placeholder="Search…"
        class="forge-field"
        style="padding-left:2rem;width:200px;font-size:13px;"
      />
    </div>
  </div>

  <!-- Table -->
  <div style="background:var(--surface-1);border:1px solid var(--border);border-radius:var(--r-md);overflow:hidden;">
    {items.length === 0 ? (
      <div class="text-center py-20">
        <p class="text-sm" style="color:var(--text-3);">No content yet. <a href="/admin/content/new" style="color:var(--accent);">Create your first item</a>.</p>
      </div>
    ) : (
      <table class="w-full" style="font-size:13px;" id="content-table">
        <thead>
          <tr style="border-bottom:1px solid var(--border);">
            <th class="text-left px-5 py-3 admin-label">Title</th>
            <th class="text-left px-4 py-3 admin-label">Type</th>
            <th class="text-left px-4 py-3 admin-label">Status</th>
            <th class="text-left px-4 py-3 admin-label hidden sm:table-cell">Rating</th>
            <th class="text-left px-4 py-3 admin-label hidden lg:table-cell">Stats</th>
            <th class="text-left px-4 py-3 admin-label hidden md:table-cell">Date</th>
            <th class="px-5 py-3"></th>
          </tr>
        </thead>
        <tbody>
          {items.map((item) => (
            <tr
              data-row={item.id}
              data-status={item.status}
              data-title={item.title.toLowerCase()}
              class="group transition-colors"
              style="border-bottom:1px solid var(--border);"
            >
              <td class="px-5 py-3.5">
                <span class="font-medium truncate block max-w-xs" style="color:var(--text-1);">{item.title}</span>
              </td>
              <td class="px-4 py-3.5">
                <span
                  class="forge-badge"
                  style={
                    item.type === "video"
                      ? "background:var(--blue-muted);color:var(--blue);"
                      : item.type === "article"
                      ? "background:var(--green-muted);color:var(--green);"
                      : "background:var(--surface-3);color:var(--text-2);"
                  }
                >
                  {item.type}
                </span>
              </td>
              <td class="px-4 py-3.5">
                <span
                  data-status-badge={item.id}
                  class="forge-badge"
                  style={
                    item.status === "published"
                      ? "background:var(--green-muted);color:var(--green);"
                      : item.status === "draft"
                      ? "background:var(--accent-muted);color:var(--accent);"
                      : "background:var(--surface-3);color:var(--text-3);"
                  }
                >
                  <span
                    class="forge-badge-dot"
                    style={
                      item.status === "published" ? "background:var(--green);"
                      : item.status === "draft" ? "background:var(--accent);"
                      : "background:var(--text-3);"
                    }
                  ></span>
                  {item.status}
                </span>
              </td>
              <td class="px-4 py-3.5 hidden sm:table-cell">
                {item.personalRating ? (
                  <div class="flex items-center gap-0.5">
                    {[1,2,3,4,5].map(n => (
                      <svg width="10" height="10" viewBox="0 0 16 16" fill={n <= item.personalRating! ? "var(--accent)" : "none"} style="color:var(--text-3);" stroke={n <= item.personalRating! ? "none" : "currentColor"} stroke-width="1.5">
                        <path d="M8 1l1.854 3.756L14 5.518l-3 2.922.708 4.128L8 10.5l-3.708 2.068L5 8.44 2 5.518l4.146-.762L8 1z"/>
                      </svg>
                    ))}
                  </div>
                ) : (
                  <span style="color:var(--text-3);">—</span>
                )}
              </td>
              <td class="px-4 py-3.5 hidden lg:table-cell">
                {(() => {
                  const m = metricsMap.get(item.id);
                  if (!m || (m.views === 0 && m.likes === 0)) return <span style="color:var(--text-3);">—</span>;
                  return (
                    <div class="flex items-center gap-2.5 text-xs" style="color:var(--text-2);">
                      {m.views > 0 && <span title="Views" class="flex items-center gap-1">
                        <svg width="11" height="11" viewBox="0 0 16 16" fill="none" style="color:var(--text-3);"><path d="M1 8s3-6 7-6 7 6 7 6-3 6-7 6-7-6-7-6z" stroke="currentColor" stroke-width="1.4"/><circle cx="8" cy="8" r="2" stroke="currentColor" stroke-width="1.4"/></svg>
                        {fmt(m.views)}
                      </span>}
                      {m.likes > 0 && <span title="Likes" class="flex items-center gap-1" style="color:var(--accent);">
                        <svg width="11" height="11" viewBox="0 0 16 16" fill="currentColor"><path d="M8 14s-6-4.35-6-8a4 4 0 0 1 6-3.46A4 4 0 0 1 14 6c0 3.65-6 8-6 8z"/></svg>
                        {fmt(m.likes)}
                      </span>}
                      {m.comments > 0 && <span title="Comments" class="flex items-center gap-1">
                        <svg width="11" height="11" viewBox="0 0 16 16" fill="none" style="color:var(--text-3);"><path d="M14 2H2a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1h3l3 3 3-3h3a1 1 0 0 0 1-1V3a1 1 0 0 0-1-1z" stroke="currentColor" stroke-width="1.4"/></svg>
                        {fmt(m.comments)}
                      </span>}
                    </div>
                  );
                })()}
              </td>
              <td class="px-4 py-3.5 text-xs hidden md:table-cell" style="color:var(--text-2);">
                {item.publishedAt
                  ? item.publishedAt.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })
                  : <span style="color:var(--text-3);">—</span>}
              </td>
              <td class="px-5 py-3.5">
                <div class="flex items-center justify-end gap-1.5 opacity-0 group-hover:opacity-100 transition-opacity">
                  <a
                    href={`/admin/content/${item.id}`}
                    class="forge-btn forge-btn-secondary"
                    style="font-size:11px;padding:0.25rem 0.6rem;"
                  >
                    Edit
                  </a>
                  <button
                    data-status-btn={item.id}
                    data-current={item.status}
                    class="forge-btn forge-btn-secondary"
                    style="font-size:11px;padding:0.25rem 0.6rem;"
                  >
                    {item.status === "published" ? "Archive" : "Publish"}
                  </button>
                  <button
                    data-delete-btn={item.id}
                    class="forge-btn forge-btn-danger"
                    style="font-size:11px;padding:0.25rem 0.6rem;"
                  >
                    Delete
                  </button>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>

</div>
</AdminLayout>

<style>
  tr[data-row]:hover { background: var(--surface-2); }
</style>

<script>
  import { adminOrpc } from "../../../lib/admin-orpc";

  // ── Tab filter ────────────────────────────────────────────────────────────────
  const tabs = document.querySelectorAll("[data-tab]");
  const searchInput = document.getElementById("search-input") as HTMLInputElement;

  function filterRows() {
    const activeTab = (document.querySelector("[data-tab].active-tab") as HTMLElement)?.dataset.tab ?? "all";
    const query = searchInput?.value.toLowerCase() ?? "";

    document.querySelectorAll("[data-row]").forEach((row) => {
      const el = row as HTMLElement;
      const status = el.dataset.status ?? "";
      const title = el.dataset.title ?? "";
      const matchTab = activeTab === "all" || status === activeTab;
      const matchSearch = !query || title.includes(query);
      el.style.display = matchTab && matchSearch ? "" : "none";
    });
  }

  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      tabs.forEach((t) => {
        const el = t as HTMLElement;
        el.classList.remove("active-tab");
        el.style.color = "var(--text-2)";
        el.style.borderBottomColor = "transparent";
        el.style.fontWeight = "";
      });
      const el = tab as HTMLElement;
      el.classList.add("active-tab");
      el.style.color = "var(--accent)";
      el.style.borderBottomColor = "var(--accent)";
      el.style.fontWeight = "500";
      filterRows();
    });
  });

  searchInput?.addEventListener("input", filterRows);

  // Mark first tab active
  (tabs[0] as HTMLElement)?.classList.add("active-tab");

  // ── Status toggle ─────────────────────────────────────────────────────────────
  document.querySelectorAll("[data-status-btn]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const id = (btn as HTMLElement).dataset.statusBtn!;
      const current = (btn as HTMLElement).dataset.current!;
      const next = current === "published" ? "archived" : "published";

      (btn as HTMLButtonElement).disabled = true;
      (btn as HTMLButtonElement).textContent = "…";

      try {
        await adminOrpc.content.setStatus({ id, status: next as any });
        const badge = document.querySelector(`[data-status-badge="${id}"]`) as HTMLElement;
        if (badge) {
          const dot = badge.querySelector(".forge-badge-dot") as HTMLElement;
          if (next === "published") {
            badge.style.cssText = "background:var(--green-muted);color:var(--green);";
            if (dot) dot.style.background = "var(--green)";
          } else {
            badge.style.cssText = "background:var(--surface-3);color:var(--text-3);";
            if (dot) dot.style.background = "var(--text-3)";
          }
          const textNode = [...badge.childNodes].find(n => n.nodeType === 3);
          if (textNode) textNode.textContent = next;
        }
        const row = document.querySelector(`[data-row="${id}"]`) as HTMLElement;
        if (row) row.dataset.status = next;
        (btn as HTMLElement).dataset.current = next;
        (btn as HTMLButtonElement).textContent = next === "published" ? "Archive" : "Publish";
        filterRows();
      } catch {
        (btn as HTMLButtonElement).textContent = "Error";
      } finally {
        (btn as HTMLButtonElement).disabled = false;
      }
    });
  });

  // ── Delete ────────────────────────────────────────────────────────────────────
  document.querySelectorAll("[data-delete-btn]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const id = (btn as HTMLElement).dataset.deleteBtn!;
      if (!confirm("Delete this item? This cannot be undone.")) return;

      (btn as HTMLButtonElement).disabled = true;
      (btn as HTMLButtonElement).textContent = "…";

      try {
        await adminOrpc.content.delete({ id });
        document.querySelector(`[data-row="${id}"]`)?.remove();
      } catch {
        (btn as HTMLButtonElement).textContent = "Error";
        (btn as HTMLButtonElement).disabled = false;
      }
    });
  });
</script>
