---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { db } from "@portify/db";
import { contentItems } from "@portify/db/schema/content";
import { platformMetrics } from "@portify/db/schema/metrics";
import { desc } from "drizzle-orm";

const items = await db
  .select()
  .from(contentItems)
  .orderBy(desc(contentItems.createdAt));

const latestMetrics = await db
  .selectDistinctOn([platformMetrics.contentItemId], {
    contentItemId: platformMetrics.contentItemId,
    views: platformMetrics.views,
    likes: platformMetrics.likes,
    comments: platformMetrics.comments,
    shares: platformMetrics.shares,
  })
  .from(platformMetrics)
  .orderBy(platformMetrics.contentItemId, desc(platformMetrics.fetchedAt));

const metricsMap = new Map(latestMetrics.map(m => [m.contentItemId, m]));

function fmt(n: number): string {
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1).replace(/\.0$/, "") + "M";
  if (n >= 1_000) return (n / 1_000).toFixed(1).replace(/\.0$/, "") + "K";
  return String(n);
}
---

<AdminLayout title="Content">
<div class="px-8 py-10">

  <!-- Header -->
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-white mb-1">Content</h1>
      <p class="text-neutral-500 text-sm">{items.length} item{items.length !== 1 ? "s" : ""}</p>
    </div>
    <a
      href="/admin/content/new"
      class="inline-flex items-center gap-1.5 bg-white text-black text-sm font-semibold px-4 py-2.5 rounded-xl hover:bg-neutral-100 transition-colors"
    >
      + New
    </a>
  </div>

  <!-- Table -->
  <div class="bg-neutral-900 border border-neutral-800 rounded-2xl overflow-hidden">
    {items.length === 0 ? (
      <div class="text-center py-20 text-neutral-600">
        <p class="text-4xl mb-3">📭</p>
        <p class="text-sm">No content yet. <a href="/admin/content/new" class="text-indigo-400 hover:underline">Create your first item</a>.</p>
      </div>
    ) : (
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-neutral-800">
            <th class="text-left px-5 py-3.5 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Title</th>
            <th class="text-left px-4 py-3.5 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Type</th>
            <th class="text-left px-4 py-3.5 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Status</th>
            <th class="text-left px-4 py-3.5 text-xs font-semibold text-neutral-500 uppercase tracking-wider hidden sm:table-cell">Rating</th>
            <th class="text-left px-4 py-3.5 text-xs font-semibold text-neutral-500 uppercase tracking-wider hidden lg:table-cell">Stats</th>
            <th class="text-left px-4 py-3.5 text-xs font-semibold text-neutral-500 uppercase tracking-wider hidden md:table-cell">Date</th>
            <th class="px-5 py-3.5"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-neutral-800">
          {items.map((item) => (
            <tr data-row={item.id} class="hover:bg-neutral-800/30 transition-colors">
              <td class="px-5 py-4">
                <span class="text-white font-medium leading-snug block truncate max-w-xs">{item.title}</span>
              </td>
              <td class="px-4 py-4">
                <span class:list={["inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-medium capitalize border", {
                  "bg-blue-500/10 text-blue-300 border-blue-500/20": item.type === "video",
                  "bg-emerald-500/10 text-emerald-300 border-emerald-500/20": item.type === "article",
                  "bg-purple-500/10 text-purple-300 border-purple-500/20": item.type === "podcast",
                  "bg-orange-500/10 text-orange-300 border-orange-500/20": item.type === "design",
                }]}>
                  {item.type}
                </span>
              </td>
              <td class="px-4 py-4">
                <span
                  data-status-badge={item.id}
                  class:list={["inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-medium capitalize border", {
                    "bg-amber-500/10 text-amber-300 border-amber-500/20": item.status === "draft",
                    "bg-emerald-500/10 text-emerald-300 border-emerald-500/20": item.status === "published",
                    "bg-neutral-800 text-neutral-400 border-neutral-700": item.status === "archived",
                  }]}
                >
                  <span class:list={["w-1.5 h-1.5 rounded-full", {
                    "bg-amber-400": item.status === "draft",
                    "bg-emerald-400": item.status === "published",
                    "bg-neutral-500": item.status === "archived",
                  }]}></span>
                  {item.status}
                </span>
              </td>
              <td class="px-4 py-4 hidden sm:table-cell">
                {item.personalRating
                  ? <span class="text-neutral-300 text-sm">{item.personalRating}<span class="text-neutral-600 text-xs">/5</span></span>
                  : <span class="text-neutral-700">—</span>}
              </td>
              <td class="px-4 py-4 hidden lg:table-cell">
                {(() => {
                  const m = metricsMap.get(item.id)
                  if (!m || (m.views === 0 && m.likes === 0)) return <span class="text-neutral-700">—</span>
                  return (
                    <div class="flex items-center gap-2.5 text-xs text-neutral-400">
                      {m.views > 0 && <span title="Views">👁 {fmt(m.views)}</span>}
                      {m.likes > 0 && <span title="Likes">♥ {fmt(m.likes)}</span>}
                      {m.comments > 0 && <span title="Comments">💬 {fmt(m.comments)}</span>}
                    </div>
                  )
                })()}
              </td>
              <td class="px-4 py-4 text-neutral-500 text-xs hidden md:table-cell">
                {item.publishedAt
                  ? item.publishedAt.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })
                  : <span class="text-neutral-700">—</span>}
              </td>
              <td class="px-5 py-4">
                <div class="flex items-center justify-end gap-2">
                  <a
                    href={`/admin/content/${item.id}`}
                    class="px-3 py-1.5 text-xs text-neutral-300 bg-neutral-800 hover:bg-neutral-700 border border-neutral-700 hover:border-neutral-600 rounded-lg transition-all font-medium"
                  >
                    Edit
                  </a>
                  <button
                    data-status-btn={item.id}
                    data-current={item.status}
                    class="px-3 py-1.5 text-xs text-neutral-400 bg-neutral-800/50 hover:bg-neutral-800 border border-neutral-700/50 hover:border-neutral-600 rounded-lg transition-all"
                  >
                    {item.status === "published" ? "Archive" : "Publish"}
                  </button>
                  <button
                    data-delete-btn={item.id}
                    class="px-3 py-1.5 text-xs text-red-400/70 hover:text-red-400 bg-transparent hover:bg-red-500/10 border border-red-500/20 hover:border-red-500/30 rounded-lg transition-all"
                  >
                    Delete
                  </button>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>
</div>
</AdminLayout>

<script>
  import { adminOrpc } from "../../../lib/admin-orpc";

  // Status toggle
  document.querySelectorAll("[data-status-btn]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const id = (btn as HTMLElement).dataset.statusBtn!;
      const current = (btn as HTMLElement).dataset.current!;
      const next = current === "published" ? "archived" : "published";

      (btn as HTMLButtonElement).disabled = true;
      (btn as HTMLButtonElement).textContent = "…";

      try {
        await adminOrpc.content.setStatus({ id, status: next as any });
        const badge = document.querySelector(`[data-status-badge="${id}"]`) as HTMLElement;
        if (badge) {
          badge.innerHTML = `<span class="w-1.5 h-1.5 rounded-full ${next === "published" ? "bg-emerald-400" : "bg-neutral-500"}"></span>${next}`;
          badge.className = "inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-medium capitalize border " +
            (next === "published"
              ? "bg-emerald-500/10 text-emerald-300 border-emerald-500/20"
              : "bg-neutral-800 text-neutral-400 border-neutral-700");
        }
        (btn as HTMLElement).dataset.current = next;
        (btn as HTMLButtonElement).textContent = next === "published" ? "Archive" : "Publish";
      } catch {
        (btn as HTMLButtonElement).textContent = "Error";
      } finally {
        (btn as HTMLButtonElement).disabled = false;
      }
    });
  });

  // Delete
  document.querySelectorAll("[data-delete-btn]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const id = (btn as HTMLElement).dataset.deleteBtn!;
      if (!confirm("Delete this item? This cannot be undone.")) return;

      (btn as HTMLButtonElement).disabled = true;
      (btn as HTMLButtonElement).textContent = "…";

      try {
        await adminOrpc.content.delete({ id });
        document.querySelector(`[data-row="${id}"]`)?.remove();
      } catch {
        (btn as HTMLButtonElement).textContent = "Error";
        (btn as HTMLButtonElement).disabled = false;
      }
    });
  });
</script>
