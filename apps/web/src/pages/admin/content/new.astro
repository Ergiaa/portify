---
import AdminLayout from "../../../layouts/AdminLayout.astro";
---

<AdminLayout title="New content">
<div class="px-8 py-10 max-w-2xl">

  <!-- Header -->
  <div class="mb-7">
    <a href="/admin/content" class="inline-flex items-center gap-1.5 text-xs mb-5 transition-colors" style="color:var(--text-3);">
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M7.5 9L4.5 6L7.5 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Back to content
    </a>
    <h1 class="font-bold" style="font-size:21px;color:var(--text-1);">New content</h1>
    <p class="text-sm mt-1" style="color:var(--text-2);">Saved as draft until published.</p>
  </div>

  <!-- Form card -->
  <div style="background:var(--surface-2);border:1px solid var(--border);border-radius:var(--r-md);padding:1.5rem;">
    <form id="create-form" novalidate>

      <!-- Thumbnail dropzone -->
      <div class="mb-5">
        <label class="block admin-label mb-2">Thumbnail</label>
        <div
          id="thumbnail-drop"
          class="relative w-full cursor-pointer overflow-hidden flex items-center justify-center"
          style="height:200px;border:1.5px dashed var(--border);border-radius:var(--r-md);background:var(--surface-1);transition:border-color 0.15s,background 0.15s;"
        >
          <img id="thumbnail-preview" src="" alt="" class="absolute inset-0 w-full h-full object-cover hidden" />
          <div id="thumbnail-placeholder" class="flex flex-col items-center gap-2 pointer-events-none" style="color:var(--text-3);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M21 15V19C21 20.1046 20.1046 21 19 21H5C3.89543 21 3 20.1046 3 19V15M17 8L12 3M12 3L7 8M12 3V15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span class="text-xs">Click to upload thumbnail</span>
          </div>
        </div>
        <input id="thumbnail-file" type="file" accept="image/*" class="hidden" />
        <input id="thumbnailUrl" name="thumbnailUrl" type="hidden" value="" />
        <p id="thumbnail-error" class="hidden mt-1.5 text-xs" style="color:var(--red);"></p>
      </div>

      <!-- Title -->
      <div class="mb-5">
        <label for="title" class="block admin-label mb-1.5">Title <span style="color:var(--red);">*</span></label>
        <input id="title" name="title" type="text" required
          placeholder="e.g. Parasite (2019) — A Masterclass in Class Tension"
          class="forge-field" />
      </div>

      <!-- Type + Platform -->
      <div class="grid grid-cols-2 gap-4 mb-5">
        <div>
          <label for="type" class="block admin-label mb-1.5">Type <span style="color:var(--red);">*</span></label>
          <select id="type" name="type" required class="forge-field" style="appearance:none;cursor:pointer;">
            <option value="">Select type</option>
            <option value="video">Video</option>
            <option value="article">Article</option>
            <option value="podcast">Podcast</option>
            <option value="design">Design</option>
          </select>
        </div>
        <div>
          <label for="platform" class="block admin-label mb-1.5">Platform</label>
          <select id="platform" name="platform" class="forge-field" style="appearance:none;cursor:pointer;">
            <option value="">None</option>
            <option value="tiktok">TikTok</option>
            <option value="instagram">Instagram</option>
            <option value="youtube">YouTube</option>
          </select>
        </div>
      </div>

      <!-- Description -->
      <div class="mb-5">
        <label for="description" class="block admin-label mb-1.5">Description</label>
        <textarea id="description" name="description" rows="3"
          placeholder="Short description shown on the portfolio…"
          class="forge-field" style="resize:none;"></textarea>
      </div>

      <!-- Platform URL -->
      <div class="mb-5">
        <label for="externalUrl" class="block admin-label mb-1.5">Platform Post URL</label>
        <input id="externalUrl" name="externalUrl" type="url"
          placeholder="Paste a TikTok or Instagram post URL…"
          class="forge-field" />
        <div id="sync-hint" class="hidden mt-2 flex items-center gap-2 px-3 py-2 text-xs" style="background:var(--accent-muted);border-radius:var(--r-sm);color:var(--accent);">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8M16 6l-4-4-4 4M12 2v13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <span id="sync-hint-text"></span>
        </div>
      </div>

      <!-- Personal Rating (StarRating) -->
      <div class="mb-7">
        <label class="block admin-label mb-2">Personal Rating</label>
        <div id="star-rating" class="flex items-center gap-1" data-value="0">
          {[1,2,3,4,5].map(n => (
            <button
              type="button"
              data-star={n}
              class="star-btn transition-colors"
              style="background:transparent;border:none;cursor:pointer;padding:2px;"
              aria-label={`${n} star`}
            >
              <svg width="18" height="18" viewBox="0 0 16 16" fill="none" style="color:var(--text-3);">
                <path d="M8 1l1.854 3.756L14 5.518l-3 2.922.708 4.128L8 10.5l-3.708 2.068L5 8.44 2 5.518l4.146-.762L8 1z" stroke="currentColor" stroke-width="1.2"/>
              </svg>
            </button>
          ))}
          <span id="star-label" class="text-xs ml-2" style="color:var(--text-3);">No rating</span>
        </div>
        <input id="personalRating" name="personalRating" type="hidden" value="" />
      </div>

      <div id="error-msg" class="hidden mb-4 px-4 py-3 text-sm" style="background:var(--red-muted);border:1px solid oklch(65% 0.2 25 / 0.2);border-radius:var(--r-sm);color:var(--red);"></div>

      <!-- Action row -->
      <div class="flex items-center gap-3 pt-4" style="border-top:1px solid var(--border);">
        <button id="submit-btn" type="submit" class="forge-btn forge-btn-primary">Save as draft</button>
        <a href="/admin/content" class="forge-btn forge-btn-ghost" style="text-decoration:none;">Cancel</a>
      </div>

    </form>
  </div>
</div>
</AdminLayout>

<script>
  import { adminOrpc } from "../../../lib/admin-orpc";

  // ── Thumbnail drop ─────────────────────────────────────────────────────────────
  const thumbnailDrop = document.getElementById("thumbnail-drop") as HTMLDivElement;
  const thumbnailFile = document.getElementById("thumbnail-file") as HTMLInputElement;
  const thumbnailPreview = document.getElementById("thumbnail-preview") as HTMLImageElement;
  const thumbnailPlaceholder = document.getElementById("thumbnail-placeholder") as HTMLDivElement;
  const thumbnailUrlInput = document.getElementById("thumbnailUrl") as HTMLInputElement;
  const thumbnailError = document.getElementById("thumbnail-error") as HTMLParagraphElement;

  thumbnailDrop.addEventListener("click", () => thumbnailFile.click());
  thumbnailDrop.addEventListener("dragover", (e) => {
    e.preventDefault();
    thumbnailDrop.style.borderColor = "var(--accent)";
    thumbnailDrop.style.background = "var(--accent-muted)";
  });
  thumbnailDrop.addEventListener("dragleave", () => {
    thumbnailDrop.style.borderColor = "var(--border)";
    thumbnailDrop.style.background = "var(--surface-1)";
  });
  thumbnailDrop.addEventListener("drop", (e) => {
    e.preventDefault();
    thumbnailDrop.style.borderColor = "var(--border)";
    thumbnailDrop.style.background = "var(--surface-1)";
    const f = e.dataTransfer?.files[0];
    if (f) { thumbnailFile.files; uploadThumbnail(f); }
  });

  thumbnailFile.addEventListener("change", () => {
    const file = thumbnailFile.files?.[0];
    if (file) uploadThumbnail(file);
  });

  async function uploadThumbnail(file: File) {
    thumbnailError.classList.add("hidden");
    const token = document.cookie.split("; ").find(c => c.startsWith("auth_token="))?.split("=")[1] ?? "";
    const fd = new FormData();
    fd.append("file", file);
    thumbnailDrop.style.opacity = "0.5";
    thumbnailDrop.style.pointerEvents = "none";
    try {
      const res = await fetch(`${import.meta.env.PUBLIC_SERVER_URL}/uploads/thumbnail`, {
        method: "POST",
        headers: { Authorization: `Bearer ${token}` },
        body: fd,
      });
      if (!res.ok) {
        const err = await res.json().catch(() => ({})) as any;
        throw new Error(err.error ?? "Upload failed");
      }
      const { url } = await res.json() as { url: string };
      thumbnailUrlInput.value = url;
      thumbnailPreview.src = url;
      thumbnailPreview.classList.remove("hidden");
      thumbnailPlaceholder.classList.add("hidden");
    } catch (err: any) {
      thumbnailError.textContent = err.message ?? "Upload failed";
      thumbnailError.classList.remove("hidden");
    } finally {
      thumbnailDrop.style.opacity = "";
      thumbnailDrop.style.pointerEvents = "";
    }
  }

  // ── StarRating ─────────────────────────────────────────────────────────────────
  const starRating = document.getElementById("star-rating") as HTMLDivElement;
  const starLabel = document.getElementById("star-label") as HTMLSpanElement;
  const ratingInput = document.getElementById("personalRating") as HTMLInputElement;
  const labels = ["No rating", "Poor", "Fair", "Good", "Great", "Excellent"];

  function renderStars(value: number, hover = -1) {
    const effective = hover >= 0 ? hover : value;
    document.querySelectorAll(".star-btn svg").forEach((svg, i) => {
      const filled = i < effective;
      (svg as SVGElement).setAttribute("fill", filled ? "var(--accent)" : "none");
      (svg as SVGElement).style.color = filled ? "var(--accent)" : "var(--text-3)";
    });
    const displayVal = hover >= 0 ? hover : value;
    starLabel.textContent = labels[displayVal] ?? "No rating";
    starLabel.style.color = displayVal > 0 ? "var(--accent)" : "var(--text-3)";
  }

  let currentRating = 0;
  starRating.querySelectorAll(".star-btn").forEach((btn) => {
    const n = parseInt((btn as HTMLElement).dataset.star!);
    btn.addEventListener("mouseenter", () => renderStars(currentRating, n));
    btn.addEventListener("mouseleave", () => renderStars(currentRating));
    btn.addEventListener("click", () => {
      currentRating = currentRating === n ? 0 : n;
      ratingInput.value = currentRating > 0 ? String(currentRating) : "";
      renderStars(currentRating);
    });
  });

  // ── Sync hint ──────────────────────────────────────────────────────────────────
  const externalUrlInput = document.getElementById("externalUrl") as HTMLInputElement;
  const platformSelect = document.getElementById("platform") as HTMLSelectElement;
  const syncHint = document.getElementById("sync-hint") as HTMLDivElement;
  const syncHintText = document.getElementById("sync-hint-text") as HTMLSpanElement;

  function detectPlatform(url: string): string | null {
    try {
      const host = new URL(url).hostname;
      if (host.includes("tiktok.com")) return "tiktok";
      if (host.includes("instagram.com")) return "instagram";
      if (host.includes("youtube.com") || host.includes("youtu.be")) return "youtube";
    } catch {}
    return null;
  }

  function updateSyncHint() {
    const url = externalUrlInput.value.trim();
    const platform = platformSelect.value;
    if (url && platform) {
      syncHintText.textContent = `Linked to ${platform} — will be included in the next sync`;
      syncHint.classList.remove("hidden");
      syncHint.style.display = "flex";
    } else {
      syncHint.classList.add("hidden");
      syncHint.style.display = "";
    }
  }

  externalUrlInput.addEventListener("input", () => {
    const detected = detectPlatform(externalUrlInput.value.trim());
    if (detected) platformSelect.value = detected;
    updateSyncHint();
  });
  platformSelect.addEventListener("change", updateSyncHint);

  // ── Form submit ────────────────────────────────────────────────────────────────
  const form = document.getElementById("create-form") as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const errorMsg = document.getElementById("error-msg") as HTMLDivElement;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    errorMsg.classList.add("hidden");

    const title = (document.getElementById("title") as HTMLInputElement).value.trim();
    const type = (document.getElementById("type") as HTMLSelectElement).value;

    if (!title || !type) {
      errorMsg.textContent = "Title and type are required.";
      errorMsg.classList.remove("hidden");
      return;
    }

    const description = (document.getElementById("description") as HTMLTextAreaElement).value.trim() || undefined;
    const externalUrl = externalUrlInput.value.trim() || undefined;
    const platform = platformSelect.value || undefined;
    const ratingVal = ratingInput.value;
    const personalRating = ratingVal ? parseInt(ratingVal) : undefined;
    const thumbnailUrl = thumbnailUrlInput.value.trim() || undefined;

    submitBtn.disabled = true;
    submitBtn.textContent = "Saving…";

    try {
      await adminOrpc.content.create({
        title,
        type: type as any,
        description,
        thumbnailUrl,
        externalUrl,
        platform: platform as any,
        personalRating,
      });
      window.location.href = "/admin/content";
    } catch (err: any) {
      errorMsg.textContent = err?.message ?? "Something went wrong. Please try again.";
      errorMsg.classList.remove("hidden");
      submitBtn.disabled = false;
      submitBtn.textContent = "Save as draft";
    }
  });
</script>
