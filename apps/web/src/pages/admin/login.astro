---
if (Astro.cookies.has("auth_token")) {
  return Astro.redirect("/admin");
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign in — Admin</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg:           oklch(10% 0.01 44);
        --surface-2:    oklch(16% 0.016 44);
        --surface-1:    oklch(13% 0.014 44);
        --accent:       oklch(71% 0.17 57);
        --text-1:       oklch(93% 0.006 44);
        --text-2:       oklch(65% 0.006 44);
        --text-3:       oklch(40% 0.006 44);
        --border:       oklch(100% 0 0 / 0.08);
        --red:          oklch(65% 0.2 25);
        --r-xs: 2px; --r-sm: 3px; --r-md: 5px; --r-lg: 8px;
      }

      body {
        min-height: 100svh;
        background: var(--bg);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
        font-family: 'IBM Plex Sans', -apple-system, BlinkMacSystemFont, sans-serif;
        color: var(--text-1);
        -webkit-font-smoothing: antialiased;
      }

      .container {
        width: 100%;
        max-width: 380px;
      }

      .brand {
        text-align: center;
        margin-bottom: 2rem;
      }
      .brand-mark {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        background: var(--accent);
        border-radius: var(--r-xs);
        margin-bottom: 0.75rem;
        font-size: 15px;
        font-weight: 700;
        color: oklch(10% 0.01 44);
      }
      .brand-name {
        font-size: 10.5px;
        font-weight: 600;
        letter-spacing: 0.07em;
        text-transform: uppercase;
        color: var(--text-3);
      }

      .card {
        background: var(--surface-2);
        border: 1px solid var(--border);
        border-radius: var(--r-lg);
        padding: 1.75rem;
      }

      .card-title {
        font-size: 17px;
        font-weight: 700;
        color: var(--text-1);
        margin-bottom: 0.2rem;
      }
      .card-subtitle {
        font-size: 13px;
        color: var(--text-2);
        margin-bottom: 1.5rem;
      }

      .field { margin-bottom: 1rem; }
      label {
        display: block;
        font-size: 10.5px;
        font-weight: 600;
        letter-spacing: 0.07em;
        text-transform: uppercase;
        color: var(--text-3);
        margin-bottom: 0.4rem;
      }
      input {
        width: 100%;
        background: var(--surface-1);
        border: 1px solid var(--border);
        border-radius: var(--r-sm);
        padding: 0.5rem 0.75rem;
        font-size: 13px;
        color: var(--text-1);
        outline: none;
        transition: border-color 0.15s, outline 0.15s;
        font-family: inherit;
      }
      input::placeholder { color: var(--text-3); }
      input:focus {
        border-color: var(--accent);
        outline: 2px solid var(--accent);
        outline-offset: -2px;
      }

      .error {
        display: none;
        align-items: center;
        gap: 0.5rem;
        background: oklch(65% 0.2 25 / 0.1);
        border: 1px solid oklch(65% 0.2 25 / 0.2);
        border-radius: var(--r-sm);
        padding: 0.5rem 0.75rem;
        font-size: 13px;
        color: var(--red);
        margin-bottom: 1rem;
      }
      .error.visible { display: flex; }

      .btn {
        width: 100%;
        background: var(--accent);
        color: oklch(10% 0.01 44);
        border: none;
        border-radius: var(--r-sm);
        padding: 0.55rem 1rem;
        font-size: 13px;
        font-weight: 600;
        font-family: inherit;
        cursor: pointer;
        transition: opacity 0.15s;
        margin-top: 0.25rem;
      }
      .btn:hover { opacity: 0.82; }
      .btn:disabled { opacity: 0.4; cursor: not-allowed; }

      .footer {
        text-align: center;
        margin-top: 1.25rem;
        font-size: 12px;
        color: var(--text-3);
      }
    </style>
  </head>
  <body>
    <div class="container">

      <div class="brand">
        <div class="brand-mark">P</div>
        <div class="brand-name">Portify</div>
      </div>

      <div class="card">
        <p class="card-title">Welcome back</p>
        <p class="card-subtitle">Sign in to manage your portfolio.</p>

        <form id="login-form" novalidate>
          <div class="field">
            <label for="email">Email address</label>
            <input
              id="email"
              type="email"
              autocomplete="email"
              placeholder="you@example.com"
              required
            />
          </div>

          <div class="field">
            <label for="password">Password</label>
            <input
              id="password"
              type="password"
              autocomplete="current-password"
              placeholder="••••••••"
              required
            />
          </div>

          <div id="error-msg" class="error">
            <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor">
              <path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1zm0 3.5a.75.75 0 0 1 .75.75v3a.75.75 0 0 1-1.5 0v-3A.75.75 0 0 1 8 4.5zm0 7a.875.875 0 1 1 0-1.75.875.875 0 0 1 0 1.75z"/>
            </svg>
            Invalid email or password.
          </div>

          <button id="submit-btn" class="btn" type="submit">Sign in</button>
        </form>
      </div>

      <p class="footer">Admin access only &mdash; no public registration.</p>
    </div>

    <script>
      import { orpc } from "../../lib/orpc";

      const form = document.getElementById("login-form") as HTMLFormElement;
      const emailInput = document.getElementById("email") as HTMLInputElement;
      const passwordInput = document.getElementById("password") as HTMLInputElement;
      const errorMsg = document.getElementById("error-msg") as HTMLDivElement;
      const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;

      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        errorMsg.classList.remove("visible");
        submitBtn.disabled = true;
        submitBtn.textContent = "Signing in…";

        try {
          const { token } = await orpc.auth.login({
            email: emailInput.value,
            password: passwordInput.value,
          });
          const maxAge = 7 * 24 * 60 * 60;
          document.cookie = `auth_token=${token}; path=/; max-age=${maxAge}; SameSite=Strict`;
          window.location.href = "/admin";
        } catch {
          errorMsg.classList.add("visible");
          submitBtn.disabled = false;
          submitBtn.textContent = "Sign in";
        }
      });
    </script>
  </body>
</html>
