---
import AdminLayout from "../../../layouts/AdminLayout.astro";

const serverYear = new Date().getFullYear();
const yearOptions = Array.from({ length: 10 }, (_, i) => serverYear - i);
---

<AdminLayout title="Import TikTok data">
<div class="px-8 py-10 max-w-2xl">

  <div class="mb-7">
    <!-- <a href="/admin" class="inline-flex items-center gap-1.5 text-xs mb-5 transition-colors" style="color:var(--text-3);"> -->
    <!--   <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M7.5 9L4.5 6L7.5 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg> -->
    <!--   Dashboard -->
    <!-- </a> -->
    <h1 class="font-bold" style="font-size:21px;color:var(--text-1);">Import TikTok data</h1>
    <p class="text-sm mt-1" style="color:var(--text-2);">
      Export from TikTok Studio → Analytics → Overview, then drop the CSV here.
    </p>
  </div>

  <!-- ── Step 1: Upload ── -->
  <div id="step-upload">
    <div
      id="drop-zone"
      class="relative w-full flex flex-col items-center justify-center gap-4 cursor-pointer transition-all"
      style="border:1.5px dashed var(--border);border-radius:var(--r-md);background:var(--surface-1);padding:4rem 2rem;"
    >
      <div class="flex items-center justify-center" style="width:44px;height:44px;border-radius:var(--r-md);background:var(--surface-2);border:1px solid var(--border);">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" style="color:var(--text-3);">
          <path d="M21 15V19C21 20.1046 20.1046 21 19 21H5C3.89543 21 3 20.1046 3 19V15M17 8L12 3M12 3L7 8M12 3V15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <div class="text-center">
        <p class="text-sm font-medium" style="color:var(--text-1);">Drop your CSV here</p>
        <p class="text-xs mt-1" style="color:var(--text-3);">or click to browse</p>
      </div>
      <p class="text-xs" style="color:var(--text-3);">Any date range · Any length</p>
    </div>
    <input id="csv-input" type="file" accept=".csv,text/csv" class="hidden" />

    <!-- Info banner -->
    <div class="mt-4 px-4 py-3 flex items-start gap-2.5" style="background:var(--surface-2);border:1px solid var(--border);border-radius:var(--r-sm);">
      <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor" class="mt-0.5 shrink-0" style="color:var(--text-3);">
        <path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1zm0 3a.75.75 0 1 1 0 1.5A.75.75 0 0 1 8 4zm.75 7.25h-1.5v-4.5h1.5v4.5z"/>
      </svg>
      <p class="text-xs" style="color:var(--text-2);">
        Go to <strong style="color:var(--text-1);">TikTok Studio → Analytics → Overview</strong>, set your date range, then click Export.
      </p>
    </div>
  </div>

  <!-- ── Step 2: Preview ── -->
  <div id="step-preview" class="hidden space-y-4">

    <!-- File chip -->
    <div class="flex items-center gap-3 px-4 py-3" style="background:var(--surface-2);border:1px solid var(--border);border-radius:var(--r-sm);">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" class="shrink-0" style="color:var(--text-3);">
        <path d="M14 2H6C4.89543 2 4 2.89543 4 4V20C4 21.1046 4.89543 22 6 22H18C19.1046 22 20 21.1046 20 20V8L14 2Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M14 2V8H20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <div class="flex-1 min-w-0">
        <p id="file-name" class="text-sm font-medium truncate" style="color:var(--text-1);"></p>
        <p id="file-size" class="text-xs" style="color:var(--text-2);"></p>
      </div>
      <button id="clear-btn" class="p-1.5 transition-colors" style="background:transparent;border:none;cursor:pointer;color:var(--text-3);border-radius:var(--r-xs);">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M18 6L6 18M6 6L18 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
    </div>

    <!-- Parse summary card -->
    <div class="space-y-5 p-5" style="background:var(--surface-2);border:1px solid var(--border);border-radius:var(--r-md);">

      <!-- Headline stats -->
      <div class="flex items-end gap-8">
        <div>
          <p id="row-count" class="font-bold tabular-nums" style="font-size:34px;color:var(--text-1);line-height:1;"></p>
          <p class="text-xs mt-1 admin-label">Days detected</p>
        </div>
        <div class="pb-1">
          <p id="date-range" class="text-sm font-medium" style="color:var(--text-1);font-family:'IBM Plex Mono',monospace;"></p>
          <p class="text-xs mt-0.5 admin-label">Date range</p>
        </div>
      </div>

      <!-- Year picker -->
      <div id="year-picker-row" class="hidden flex items-center gap-3 px-3 py-2.5" style="background:var(--accent-muted);border-radius:var(--r-sm);">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" class="shrink-0" style="color:var(--accent);">
          <path d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <p class="text-xs flex-1" style="color:var(--accent);">Dates have no year — starting from:</p>
        <select
          id="start-year"
          class="forge-field"
          style="width:auto;padding:0.25rem 0.5rem;font-family:'IBM Plex Mono',monospace;font-size:12px;"
        >
          {yearOptions.map(y => (
            <option value={y} selected={y === serverYear}>{y}</option>
          ))}
        </select>
      </div>

      <!-- Column badges -->
      <div>
        <p class="admin-label mb-2.5">Detected columns</p>
        <div id="column-badges" class="flex flex-wrap gap-2"></div>
      </div>

      <!-- Preview table -->
      <div>
        <p class="admin-label mb-2.5">Preview</p>
        <div class="overflow-x-auto" style="border:1px solid var(--border);border-radius:var(--r-sm);">
          <table class="w-full" style="font-size:12px;">
            <thead>
              <tr style="border-bottom:1px solid var(--border);">
                <th class="px-3 py-2.5 text-left admin-label">Date</th>
                <th class="px-3 py-2.5 text-right admin-label">Video Views</th>
                <th class="px-3 py-2.5 text-right admin-label">Profile Views</th>
                <th class="px-3 py-2.5 text-right admin-label">Likes</th>
                <th class="px-3 py-2.5 text-right admin-label">Comments</th>
                <th class="px-3 py-2.5 text-right admin-label">Shares</th>
              </tr>
            </thead>
            <tbody id="preview-tbody"></tbody>
          </table>
        </div>
        <p id="more-rows" class="hidden text-xs mt-1.5 text-right" style="color:var(--text-3);"></p>
      </div>

      <!-- Warnings -->
      <div id="warnings" class="hidden p-4 space-y-1" style="background:oklch(71% 0.17 57 / 0.06);border:1px solid oklch(71% 0.17 57 / 0.15);border-radius:var(--r-sm);">
        <p class="text-xs font-semibold" style="color:var(--accent);">Warnings</p>
        <ul id="warnings-list" class="text-xs space-y-0.5 list-disc list-inside" style="color:var(--text-2);"></ul>
      </div>

      <!-- Unknown columns -->
      <div id="unknown-cols" class="hidden px-4 py-3" style="background:var(--surface-3);border-radius:var(--r-sm);">
        <p class="text-xs" style="color:var(--text-2);">
          <span class="font-semibold" style="color:var(--text-1);">Ignored columns:</span>
          <span id="unknown-list" style="font-family:'IBM Plex Mono',monospace;" class="ml-1"></span>
        </p>
      </div>
    </div>

    <!-- Parse error -->
    <div id="parse-error" class="hidden px-4 py-3 text-sm" style="background:var(--red-muted);border:1px solid oklch(65% 0.2 25 / 0.2);border-radius:var(--r-sm);color:var(--red);"></div>

    <!-- Import CTA -->
    <button id="import-btn" class="forge-btn forge-btn-primary w-full" style="padding:0.65rem 1rem;font-size:13px;text-align:center;">
      Import <span id="import-count"></span> days
    </button>
    <p class="text-xs text-center" style="color:var(--text-3);">Duplicate dates will be skipped automatically.</p>
  </div>

  <!-- ── Step 3: Importing ── -->
  <div id="step-importing" class="hidden">
    <div class="flex flex-col items-center gap-4 p-12" style="background:var(--surface-2);border:1px solid var(--border);border-radius:var(--r-md);">
      <div class="w-7 h-7 rounded-full animate-spin" style="border:2px solid var(--border);border-top-color:var(--accent);"></div>
      <p class="text-sm" style="color:var(--text-2);">Importing…</p>
    </div>
  </div>

  <!-- ── Step 4: Done ── -->
  <div id="step-done" class="hidden space-y-4">
    <div class="p-6 space-y-5" style="background:var(--surface-2);border:1px solid var(--border);border-radius:var(--r-md);">
      <div class="flex items-center gap-3">
        <div class="flex items-center justify-center text-sm" style="width:32px;height:32px;border-radius:50%;background:var(--green-muted);border:1px solid oklch(70% 0.17 145 / 0.25);color:var(--green);">✓</div>
        <h2 class="text-sm font-semibold" style="color:var(--text-1);">Import complete</h2>
      </div>

      <div class="grid grid-cols-2 gap-3">
        <div class="px-4 py-4" style="background:var(--surface-3);border-radius:var(--r-sm);">
          <p id="result-inserted" class="font-bold tabular-nums" style="font-size:28px;color:var(--green);line-height:1;">—</p>
          <p class="text-xs mt-1" style="color:var(--text-2);">Days inserted</p>
        </div>
        <div class="px-4 py-4" style="background:var(--surface-3);border-radius:var(--r-sm);">
          <p id="result-skipped" class="font-bold tabular-nums" style="font-size:28px;color:var(--text-3);line-height:1;">—</p>
          <p class="text-xs mt-1" style="color:var(--text-2);">Already existed</p>
        </div>
      </div>

      <p id="result-range" class="text-xs" style="color:var(--text-3);font-family:'IBM Plex Mono',monospace;"></p>

      <div id="result-unknown" class="hidden text-xs" style="color:var(--text-2);">
        <span class="font-semibold" style="color:var(--text-1);">Ignored columns:</span>
        <span id="result-unknown-list" style="font-family:'IBM Plex Mono',monospace;" class="ml-1"></span>
      </div>

      <div class="flex items-center justify-between pt-1" style="border-top:1px solid var(--border);">
        <button id="import-another-btn" class="forge-btn forge-btn-ghost" style="padding:0.4rem 0;">
          ← Import another file
        </button>
        <a
          href="/admin/analytics/tiktok"
          class="forge-btn forge-btn-primary"
          style="text-decoration:none;"
        >
          View analytics →
        </a>
      </div>
    </div>
  </div>

</div>
</AdminLayout>

<script>
import { parseTikTokCsv, type TikTokDailyRow, type CsvParseOptions } from "@portify/api/lib/tiktok-csv";

const stepUpload    = document.getElementById("step-upload")!;
const stepPreview   = document.getElementById("step-preview")!;
const stepImporting = document.getElementById("step-importing")!;
const stepDone      = document.getElementById("step-done")!;

const dropZone      = document.getElementById("drop-zone")!;
const csvInput      = document.getElementById("csv-input") as HTMLInputElement;
const clearBtn      = document.getElementById("clear-btn")!;
const importBtn     = document.getElementById("import-btn")!;
const importAnotherBtn = document.getElementById("import-another-btn")!;

function showStep(step: "upload" | "preview" | "importing" | "done") {
  stepUpload.classList.toggle("hidden",    step !== "upload");
  stepPreview.classList.toggle("hidden",   step !== "preview");
  stepImporting.classList.toggle("hidden", step !== "importing");
  stepDone.classList.toggle("hidden",      step !== "done");
}

function fmtDate(iso: string) {
  const [y, m, d] = iso.split("-").map(Number);
  const months = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
  return `${months[m! - 1]} ${d}, ${y}`;
}

function fmtNum(n: number) { return n.toLocaleString(); }
function fmtFileSize(bytes: number) {
  if (bytes < 1024) return `${bytes} B`;
  if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;
  return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
}

const ALL_METRICS: { key: keyof Omit<TikTokDailyRow, "date">; label: string }[] = [
  { key: "videoViews",   label: "Video Views"   },
  { key: "profileViews", label: "Profile Views" },
  { key: "likes",        label: "Likes"         },
  { key: "comments",     label: "Comments"      },
  { key: "shares",       label: "Shares"        },
  { key: "netFollowers", label: "Net Followers" },
];

// ── Drop zone ─────────────────────────────────────────────────────────────────
dropZone.addEventListener("click", () => csvInput.click());
dropZone.addEventListener("dragover", (e) => {
  e.preventDefault();
  dropZone.style.borderColor = "var(--accent)";
  dropZone.style.background = "var(--accent-muted)";
});
dropZone.addEventListener("dragleave", () => {
  dropZone.style.borderColor = "var(--border)";
  dropZone.style.background = "var(--surface-1)";
});
dropZone.addEventListener("drop", (e) => {
  e.preventDefault();
  dropZone.style.borderColor = "var(--border)";
  dropZone.style.background = "var(--surface-1)";
  const f = e.dataTransfer?.files[0];
  if (f) loadFile(f);
});
csvInput.addEventListener("change", () => {
  const f = csvInput.files?.[0];
  if (f) loadFile(f);
});

function resetToUpload() {
  csvInput.value     = "";
  currentFile        = null;
  currentFileText    = null;
  yearPickerTouched  = false;
  startYearSel.selectedIndex = 0;
  showStep("upload");
}
clearBtn.addEventListener("click",        resetToUpload);
importAnotherBtn.addEventListener("click", resetToUpload);

// ── Year picker ───────────────────────────────────────────────────────────────
const yearPickerRow = document.getElementById("year-picker-row")!;
const startYearSel  = document.getElementById("start-year") as HTMLSelectElement;

startYearSel.addEventListener("change", () => {
  yearPickerTouched = true;
  if (currentFileText && currentFile) renderPreview(currentFile, currentFileText);
});

let currentFile: File | null = null;
let currentFileText: string | null = null;
let yearPickerTouched = false;

function loadFile(file: File) {
  yearPickerTouched = false;
  const reader = new FileReader();
  reader.onload = (e) => {
    currentFile     = file;
    currentFileText = e.target?.result as string;
    renderPreview(file, currentFileText);
  };
  reader.readAsText(file);
}

function renderPreview(file: File, text: string) {
  const opts: CsvParseOptions = yearPickerTouched ? { startYear: Number(startYearSel.value) } : {};
  const result = parseTikTokCsv(text, opts);
  const { rows, detectedMetrics, unknownColumns, errors, yearInferred, detectedStartYear } = result;

  yearPickerRow.classList.toggle("hidden", !yearInferred);
  if (yearInferred && detectedStartYear !== null && !yearPickerTouched) {
    if (!Array.from(startYearSel.options).some(o => o.value === String(detectedStartYear))) {
      const opt = document.createElement("option");
      opt.value = String(detectedStartYear);
      opt.textContent = String(detectedStartYear);
      startYearSel.appendChild(opt);
    }
    startYearSel.value = String(detectedStartYear);
  }

  (document.getElementById("file-name")!).textContent = file.name;
  (document.getElementById("file-size")!).textContent = fmtFileSize(file.size);

  const parseErrorEl = document.getElementById("parse-error")!;
  if (rows.length === 0) {
    parseErrorEl.textContent = errors[0] ?? "Could not parse this file. Check that it's a TikTok Overview CSV.";
    parseErrorEl.classList.remove("hidden");
    (importBtn as HTMLButtonElement).disabled = true;
    importBtn.style.opacity = "0.4";
  } else {
    parseErrorEl.classList.add("hidden");
    (importBtn as HTMLButtonElement).disabled = false;
    importBtn.style.opacity = "";
  }

  (document.getElementById("row-count")!).textContent = String(rows.length);
  (document.getElementById("import-count")!).textContent = String(rows.length);

  if (rows.length > 0) {
    const first = rows[0]!.date;
    const last  = rows[rows.length - 1]!.date;
    (document.getElementById("date-range")!).textContent =
      first === last ? fmtDate(first) : `${fmtDate(first)} → ${fmtDate(last)}`;
  } else {
    (document.getElementById("date-range")!).textContent = "—";
  }

  // Column badges with Forge styling
  const badgesEl = document.getElementById("column-badges")!;
  badgesEl.innerHTML = ALL_METRICS.map(m => {
    const found = detectedMetrics.includes(m.key);
    return found
      ? `<span style="display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:500;background:var(--green-muted);color:var(--green);">
           <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 5L4 7L8 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
           ${m.label}
         </span>`
      : `<span style="display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:500;background:var(--surface-3);color:var(--text-3);">
           <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M3 3L7 7M7 3L3 7" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
           ${m.label}
         </span>`;
  }).join("");

  // Preview table rows
  const PREVIEW_MAX = 8;
  const tbody = document.getElementById("preview-tbody")!;
  tbody.innerHTML = rows.slice(0, PREVIEW_MAX).map(row =>
    `<tr style="border-bottom:1px solid var(--border);">
       <td style="padding:0.5rem 0.75rem;color:var(--text-2);white-space:nowrap;font-family:'IBM Plex Mono',monospace;">${fmtDate(row.date)}</td>
       <td style="padding:0.5rem 0.75rem;text-align:right;color:var(--text-1);font-variant-numeric:tabular-nums;">${fmtNum(row.videoViews)}</td>
       <td style="padding:0.5rem 0.75rem;text-align:right;color:var(--text-2);font-variant-numeric:tabular-nums;">${fmtNum(row.profileViews)}</td>
       <td style="padding:0.5rem 0.75rem;text-align:right;color:var(--accent);font-variant-numeric:tabular-nums;">${fmtNum(row.likes)}</td>
       <td style="padding:0.5rem 0.75rem;text-align:right;color:var(--text-2);font-variant-numeric:tabular-nums;">${fmtNum(row.comments)}</td>
       <td style="padding:0.5rem 0.75rem;text-align:right;color:var(--blue);font-variant-numeric:tabular-nums;">${fmtNum(row.shares)}</td>
     </tr>`
  ).join("");

  const moreEl = document.getElementById("more-rows")!;
  if (rows.length > PREVIEW_MAX) {
    moreEl.textContent = `+${rows.length - PREVIEW_MAX} more rows not shown`;
    moreEl.classList.remove("hidden");
  } else {
    moreEl.classList.add("hidden");
  }

  const warningsEl = document.getElementById("warnings")!;
  const warningsList = document.getElementById("warnings-list")!;
  if (errors.length > 0) {
    warningsList.innerHTML = errors.slice(0, 5).map(e => `<li>${e}</li>`).join("");
    if (errors.length > 5) warningsList.innerHTML += `<li>…and ${errors.length - 5} more</li>`;
    warningsEl.classList.remove("hidden");
  } else {
    warningsEl.classList.add("hidden");
  }

  const unknownEl = document.getElementById("unknown-cols")!;
  if (unknownColumns.length > 0) {
    (document.getElementById("unknown-list")!).textContent = unknownColumns.join(", ");
    unknownEl.classList.remove("hidden");
  } else {
    unknownEl.classList.add("hidden");
  }

  showStep("preview");
}

// ── Import ─────────────────────────────────────────────────────────────────────
importBtn.addEventListener("click", async () => {
  const file = csvInput.files?.[0];
  if (!file) return;

  showStep("importing");

  const token = document.cookie.split("; ")
    .find(c => c.startsWith("auth_token="))?.split("=")[1] ?? "";
  const fd = new FormData();
  fd.append("file", file);
  if (yearPickerTouched) fd.append("startYear", startYearSel.value);

  try {
    const res = await fetch(`${import.meta.env.PUBLIC_SERVER_URL}/uploads/tiktok-csv`, {
      method: "POST",
      headers: { Authorization: `Bearer ${token}` },
      body: fd,
    });

    if (!res.ok) {
      const err = await res.json().catch(() => ({})) as any;
      throw new Error(err.error ?? `Server error ${res.status}`);
    }

    const data = await res.json() as {
      inserted: number;
      skipped: number;
      dateRange: { from: string; to: string } | null;
      unknownColumns: string[];
      errors: string[];
    };

    (document.getElementById("result-inserted")!).textContent = String(data.inserted);
    (document.getElementById("result-skipped")!).textContent  = String(data.skipped);

    const rangeEl = document.getElementById("result-range")!;
    rangeEl.textContent = data.dateRange
      ? `${fmtDate(data.dateRange.from)} → ${fmtDate(data.dateRange.to)}`
      : "";

    const resultUnknownEl = document.getElementById("result-unknown")!;
    if (data.unknownColumns.length > 0) {
      (document.getElementById("result-unknown-list")!).textContent = data.unknownColumns.join(", ");
      resultUnknownEl.classList.remove("hidden");
    } else {
      resultUnknownEl.classList.add("hidden");
    }

    showStep("done");
  } catch (err: any) {
    const parseErrorEl = document.getElementById("parse-error")!;
    parseErrorEl.textContent = err?.message ?? "Something went wrong. Please try again.";
    parseErrorEl.classList.remove("hidden");
    showStep("preview");
  }
});
</script>
