---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { db } from "@portify/db";
import { contentItems } from "@portify/db/schema/content";
import { platforms } from "@portify/db/schema/platforms";
import { eq, sql, desc } from "drizzle-orm";

const counts = await db
  .select({ status: contentItems.status, count: sql<number>`count(*)::int` })
  .from(contentItems)
  .groupBy(contentItems.status);

const byStatus = Object.fromEntries(counts.map(r => [r.status, r.count]));
const published = byStatus["published"] ?? 0;
const draft = byStatus["draft"] ?? 0;
const archived = byStatus["archived"] ?? 0;
const total = published + draft + archived;

const connectedPlatforms = await db.select({
  name: platforms.name,
  accountName: platforms.accountName,
  lastSyncedAt: platforms.lastSyncedAt,
  lastSyncStatus: platforms.lastSyncStatus,
  syncEnabled: platforms.syncEnabled,
}).from(platforms);
const platformMap = Object.fromEntries(connectedPlatforms.map(p => [p.name, p]));

const recentItems = await db
  .select()
  .from(contentItems)
  .orderBy(desc(contentItems.createdAt))
  .limit(5);

function fmtDate(d: Date | null) {
  if (!d) return "—";
  return d.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
}

const supportedPlatforms = [
  { name: "tiktok", label: "TikTok" },
  { name: "instagram", label: "Instagram" },
] as const;
---

<AdminLayout title="Dashboard">
<div class="px-8 py-10">

  <!-- Page header -->
  <div class="mb-8">
    <h1 class="font-bold mb-0.5" style="font-size:21px;color:var(--text-1);">Dashboard</h1>
    <p class="text-sm" style="color:var(--text-2);">Overview of your portfolio content.</p>
  </div>

  <!-- Stats strip: single card, 4 columns -->
  <div class="mb-6" style="background:var(--surface-2);border:1px solid var(--border);border-radius:var(--r-md);">
    <div class="grid grid-cols-4">
      {[
        { label: "Total",     value: total,     sub: "items",     color: "var(--text-1)" },
        { label: "Published", value: published,  sub: "live",      color: "var(--green)" },
        { label: "Draft",     value: draft,      sub: "pending",   color: "var(--accent)" },
        { label: "Archived",  value: archived,   sub: "hidden",    color: "var(--text-3)" },
      ].map((stat, i) => (
        <div
          class="px-6 py-5"
          style={i < 3 ? "border-right:1px solid var(--border);" : ""}
        >
          <p class="font-bold tabular-nums mb-1" style={`font-size:34px;color:${stat.color};line-height:1;`}>{stat.value}</p>
          <p class="admin-label" style="color:var(--text-3);">{stat.label}</p>
          <p class="text-xs mt-0.5" style="color:var(--text-3);">{stat.sub}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Platform sync strip -->
  <div class="grid grid-cols-2 gap-4 mb-6">
    {supportedPlatforms.map(({ name, label }) => {
      const p = platformMap[name];
      const connected = !!p;
      const hasError = p?.lastSyncStatus === "error";
      return (
        <div class="p-5" style="background:var(--surface-2);border:1px solid var(--border);border-radius:var(--r-md);">
          <div class="flex items-start justify-between gap-3">
            <div class="flex items-center gap-3">
              <!-- Status dot -->
              <span
                class="w-2 h-2 rounded-full shrink-0 mt-0.5"
                style={`background:${connected && !hasError ? "var(--green)" : hasError ? "var(--red)" : "var(--text-3)"};`}
              ></span>
              <div>
                <p class="text-sm font-medium" style="color:var(--text-1);">{label}</p>
                {connected && p.accountName ? (
                  <p class="text-xs mt-0.5" style="color:var(--text-2);">
                    @{p.accountName}
                    {p.lastSyncedAt && (
                      <> · {p.lastSyncedAt.toLocaleDateString("en-US", { month: "short", day: "numeric" })}</>
                    )}
                  </p>
                ) : (
                  <p class="text-xs mt-0.5" style="color:var(--text-3);">No account linked</p>
                )}
              </div>
            </div>
            {connected ? (
              <a href="/admin/settings/platforms" class="forge-btn forge-btn-secondary shrink-0" style="font-size:11px;padding:0.3rem 0.75rem;">Sync</a>
            ) : (
              <a href="/admin/settings/platforms" class="forge-btn forge-btn-primary shrink-0" style="font-size:11px;padding:0.3rem 0.75rem;">Connect</a>
            )}
          </div>
        </div>
      );
    })}
  </div>

  <!-- Recent content -->
  <div style="background:var(--surface-2);border:1px solid var(--border);border-radius:var(--r-md);">
    <div class="flex items-center justify-between px-5 py-4" style="border-bottom:1px solid var(--border);">
      <p class="text-sm font-semibold" style="color:var(--text-1);">Recent content</p>
      <a href="/admin/content" class="text-xs transition-colors" style="color:var(--text-2);">View all →</a>
    </div>

    {recentItems.length === 0 ? (
      <div class="px-5 py-10 text-center">
        <p class="text-sm" style="color:var(--text-3);">No content yet. <a href="/admin/content/new" style="color:var(--accent);">Create your first item</a>.</p>
      </div>
    ) : (
      <div>
        {recentItems.map((item, i) => (
          <a
            href={`/admin/content/${item.id}`}
            class="flex items-center gap-4 px-5 py-3.5 transition-colors group"
            style={`text-decoration:none;${i > 0 ? "border-top:1px solid var(--border);" : ""}`}
          >
            <!-- Thumbnail placeholder -->
            <div class="w-10 h-10 shrink-0 overflow-hidden" style="border-radius:var(--r-sm);background:var(--surface-3);">
              {item.thumbnailUrl ? (
                <img src={item.thumbnailUrl} alt="" class="w-full h-full object-cover" />
              ) : (
                <div class="w-full h-full flex items-center justify-center" style="color:var(--text-3);">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/><circle cx="8.5" cy="8.5" r="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M21 15l-5-5L5 21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
              )}
            </div>

            <!-- Title + meta -->
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium truncate" style="color:var(--text-1);">{item.title}</p>
              <p class="text-xs mt-0.5" style="color:var(--text-2);">
                {item.platform && <span class="capitalize">{item.platform}</span>}
                {item.platform && item.publishedAt && <span style="color:var(--text-3);"> · </span>}
                {item.publishedAt && <span>{fmtDate(item.publishedAt)}</span>}
                {!item.platform && !item.publishedAt && <span style="color:var(--text-3);">—</span>}
              </p>
            </div>

            <!-- Status badge -->
            <span
              class="forge-badge shrink-0"
              style={
                item.status === "published"
                  ? "background:var(--green-muted);color:var(--green);"
                  : item.status === "draft"
                  ? "background:var(--accent-muted);color:var(--accent);"
                  : "background:var(--surface-3);color:var(--text-3);"
              }
            >
              <span
                class="forge-badge-dot"
                style={
                  item.status === "published" ? "background:var(--green);"
                  : item.status === "draft" ? "background:var(--accent);"
                  : "background:var(--text-3);"
                }
              ></span>
              {item.status}
            </span>

            <!-- Star rating -->
            {item.personalRating ? (
              <div class="flex items-center gap-0.5 shrink-0">
                {[1,2,3,4,5].map(n => (
                  <svg width="11" height="11" viewBox="0 0 16 16" fill={n <= item.personalRating! ? "var(--accent)" : "none"} style="color:var(--text-3);" stroke={n <= item.personalRating! ? "none" : "currentColor"} stroke-width="1.5">
                    <path d="M8 1l1.854 3.756L14 5.518l-3 2.922.708 4.128L8 10.5l-3.708 2.068L5 8.44 2 5.518l4.146-.762L8 1z"/>
                  </svg>
                ))}
              </div>
            ) : (
              <span class="text-xs shrink-0" style="color:var(--text-3);">—</span>
            )}
          </a>
        ))}
      </div>
    )}
  </div>

</div>
</AdminLayout>
