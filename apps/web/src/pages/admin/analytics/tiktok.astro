---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { db } from "@portify/db";
import { aggregateMetrics } from "@portify/db/schema/metrics";
import { eq } from "drizzle-orm";

const rawRows = await db
  .select()
  .from(aggregateMetrics)
  .where(eq(aggregateMetrics.dimension, "period"));

type DailyRow = {
  date: string;
  videoViews: number;
  profileViews: number;
  netFollowers: number;
  likes: number;
  comments: number;
  shares: number;
};

const byDate = new Map<string, DailyRow>();
for (const m of rawRows) {
  if (!m.dimensionValue) continue;
  if (!byDate.has(m.dimensionValue)) {
    byDate.set(m.dimensionValue, {
      date: m.dimensionValue,
      videoViews: 0,
      profileViews: 0,
      netFollowers: 0,
      likes: 0,
      comments: 0,
      shares: 0,
    });
  }
  const row = byDate.get(m.dimensionValue)!;
  switch (m.metricType) {
    case "video_views":   row.videoViews   = m.value; break;
    case "profile_views": row.profileViews = m.value; break;
    case "net_followers": row.netFollowers  = m.value; break;
    case "likes":         row.likes         = m.value; break;
    case "comments":      row.comments      = m.value; break;
    case "shares":        row.shares        = m.value; break;
  }
}

const daily = [...byDate.values()].sort((a, b) => a.date.localeCompare(b.date));
const hasData = daily.length > 0;
const minDate = daily.length ? daily[0]!.date : "";
const maxDate = daily.length ? daily[daily.length - 1]!.date : "";
---

<AdminLayout title="TikTok Analytics">
<div class="px-8 py-10 max-w-6xl">

  <!-- Header -->
  <div class="mb-8">
    <a
      href="/admin/import/tiktok"
      class="inline-flex items-center gap-1.5 text-xs text-neutral-500 hover:text-neutral-300 transition-colors mb-5"
    >
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M7.5 9L4.5 6L7.5 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Import data
    </a>

    <div class="flex items-start justify-between gap-4 flex-wrap">
      <div>
        <h1 class="text-2xl font-bold text-white">TikTok Analytics</h1>
        <p id="date-range-label" class="text-neutral-500 text-sm mt-1 h-5"></p>
      </div>

      {hasData && (
        <div class="flex flex-col items-end gap-2">
          <!-- Preset + Custom buttons -->
          <div class="flex items-center gap-1 bg-neutral-900 border border-neutral-800 rounded-xl p-1">
            {[
              { key: "7d",     label: "7D" },
              { key: "30d",    label: "30D" },
              { key: "90d",    label: "90D" },
              { key: "1y",     label: "1Y" },
              { key: "all",    label: "All" },
              { key: "custom", label: "Custom" },
            ].map((r, i) => (
              <button
                data-range={r.key}
                class:list={[
                  "px-3 py-1.5 rounded-lg text-xs font-medium transition-colors",
                  i === 4
                    ? "bg-neutral-800 text-white"
                    : "text-neutral-500 hover:text-neutral-300",
                ]}
              >
                {r.label}
              </button>
            ))}
          </div>

          <!-- Custom date inputs — hidden until Custom is selected -->
          <div id="custom-range" class="hidden items-center gap-2">
            <input
              id="custom-from"
              type="date"
              min={minDate}
              max={maxDate}
              class="bg-neutral-800 border border-neutral-700 rounded-lg px-3 py-1.5 text-xs text-white [color-scheme:dark] focus:outline-none focus:border-neutral-500 transition-colors"
            />
            <span class="text-neutral-600 text-xs">→</span>
            <input
              id="custom-to"
              type="date"
              min={minDate}
              max={maxDate}
              class="bg-neutral-800 border border-neutral-700 rounded-lg px-3 py-1.5 text-xs text-white [color-scheme:dark] focus:outline-none focus:border-neutral-500 transition-colors"
            />
          </div>
        </div>
      )}
    </div>
  </div>

  {hasData ? (
    <>
      <!-- Summary cards -->
      <div class="grid grid-cols-2 sm:grid-cols-5 gap-4 mb-8">
        <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-5">
          <p id="stat-video-views" class="text-xl font-bold mb-0.5 tabular-nums text-indigo-400">—</p>
          <p class="text-xs text-neutral-500 mt-1">Total Video Views</p>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-5">
          <p id="stat-avg-views" class="text-xl font-bold mb-0.5 tabular-nums text-white">—</p>
          <p class="text-xs text-neutral-500 mt-1">Avg Daily Views</p>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-5">
          <p id="stat-likes" class="text-xl font-bold mb-0.5 tabular-nums text-pink-400">—</p>
          <p class="text-xs text-neutral-500 mt-1">Total Likes</p>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-5">
          <p id="stat-shares" class="text-xl font-bold mb-0.5 tabular-nums text-sky-400">—</p>
          <p class="text-xs text-neutral-500 mt-1">Total Shares</p>
        </div>
        <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-5">
          <p id="stat-peak-date" class="text-xl font-bold mb-0.5 tabular-nums text-amber-400">—</p>
          <p id="stat-peak-sub" class="text-xs text-neutral-500 font-mono"></p>
          <p class="text-xs text-neutral-500 mt-1">Peak Day</p>
        </div>
      </div>

      <!-- Chart -->
      <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-6 mb-8">
        <div class="flex flex-wrap gap-2 mb-6">
          {[
            { key: "videoViews",   label: "Video Views",   color: "#818cf8" },
            { key: "profileViews", label: "Profile Views", color: "#34d399" },
            { key: "likes",        label: "Likes",         color: "#f472b6" },
            { key: "comments",     label: "Comments",      color: "#fb923c" },
            { key: "shares",       label: "Shares",        color: "#60a5fa" },
          ].map((m, i) => (
            <button
              data-metric={m.key}
              data-color={m.color}
              class:list={[
                "px-3 py-1.5 rounded-lg text-xs font-medium transition-colors",
                i === 0
                  ? "bg-neutral-800 text-white"
                  : "text-neutral-500 hover:text-neutral-300",
              ]}
            >
              {m.label}
            </button>
          ))}
        </div>

        <div class="relative">
          <canvas id="chart" class="w-full block" style="height:260px"></canvas>
          <div
            id="chart-tooltip"
            class="pointer-events-none absolute hidden bg-neutral-800 border border-neutral-700 rounded-lg px-3 py-2 text-xs shadow-xl z-10 min-w-[100px]"
          ></div>
        </div>
      </div>

      <!-- Table -->
      <div class="bg-neutral-900 border border-neutral-800 rounded-2xl overflow-hidden">

        <!-- Table toolbar -->
        <div class="flex items-center justify-between px-6 py-4 border-b border-neutral-800 gap-4">
          <h2 class="text-sm font-semibold text-white shrink-0">Daily Breakdown</h2>
          <div class="flex items-center gap-3 flex-wrap justify-end">
            <button
              id="delta-toggle"
              class="px-3 py-1.5 rounded-lg text-xs font-medium text-neutral-500 hover:text-neutral-300 border border-neutral-800 hover:border-neutral-700 transition-colors"
            >
              Δ Day-over-day
            </button>
            <span id="table-row-count" class="text-xs text-neutral-500"></span>
            <button
              id="export-csv"
              class="px-3 py-1.5 rounded-lg text-xs font-medium text-neutral-400 hover:text-white border border-neutral-700 hover:border-neutral-500 transition-colors flex items-center gap-1.5"
            >
              <svg width="11" height="11" viewBox="0 0 12 12" fill="none"><path d="M2 9h8M6 2v5.5M3.5 5L6 7.5 8.5 5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Export CSV
            </button>
          </div>
        </div>

        <!-- Filter bar -->
        <div class="flex items-center gap-3 px-6 py-3 border-b border-neutral-800 flex-wrap">
          <div class="relative">
            <svg class="absolute left-2.5 top-1/2 -translate-y-1/2 text-neutral-600" width="11" height="11" viewBox="0 0 12 12" fill="none"><circle cx="5" cy="5" r="3.5" stroke="currentColor" stroke-width="1.3"/><path d="M8 8l2.5 2.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
            <input
              id="search-date"
              type="text"
              placeholder="Search date…"
              class="bg-neutral-800 border border-neutral-700 rounded-lg pl-7 pr-3 py-1.5 text-xs text-white placeholder-neutral-600 focus:outline-none focus:border-neutral-500 transition-colors w-36"
            />
          </div>

          <div class="flex items-center gap-1.5 ml-auto">
            <span class="text-xs text-neutral-600">where</span>
            <select
              id="filter-metric"
              class="bg-neutral-800 border border-neutral-700 rounded-lg px-2.5 py-1.5 text-xs text-white focus:outline-none focus:border-neutral-500 transition-colors"
            >
              <option value="videoViews">Video Views</option>
              <option value="profileViews">Profile Views</option>
              <option value="likes">Likes</option>
              <option value="comments">Comments</option>
              <option value="shares">Shares</option>
            </select>
            <span class="text-xs text-neutral-600">≥</span>
            <input
              id="filter-min"
              type="number"
              min="0"
              placeholder="Min value"
              class="bg-neutral-800 border border-neutral-700 rounded-lg px-3 py-1.5 text-xs text-white placeholder-neutral-600 focus:outline-none focus:border-neutral-500 transition-colors w-24"
            />
            <button
              id="clear-filters"
              class="px-2.5 py-1.5 rounded-lg text-xs text-neutral-600 hover:text-neutral-300 transition-colors"
            >
              Clear
            </button>
          </div>
        </div>

        <!-- Scrollable table -->
        <div class="overflow-x-auto">
          <div class="max-h-[520px] overflow-y-auto">
            <table class="w-full text-xs">
              <thead class="sticky top-0 bg-neutral-900 border-b border-neutral-800 z-10">
                <tr>
                  <th data-sort="date"         class="px-4 py-3 text-left text-neutral-500 font-medium whitespace-nowrap cursor-pointer hover:text-neutral-300 select-none transition-colors group">
                    <span class="flex items-center gap-1">Date <span id="sort-ind-date" class="opacity-40 group-hover:opacity-70">↕</span></span>
                  </th>
                  <th data-sort="videoViews"   class="px-4 py-3 text-left text-neutral-500 font-medium whitespace-nowrap cursor-pointer hover:text-neutral-300 select-none transition-colors group">
                    <span class="flex items-center gap-1">Video Views <span id="sort-ind-videoViews" class="opacity-40 group-hover:opacity-70">↕</span></span>
                  </th>
                  <th data-sort="profileViews" class="px-4 py-3 text-left text-neutral-500 font-medium whitespace-nowrap cursor-pointer hover:text-neutral-300 select-none transition-colors group">
                    <span class="flex items-center gap-1">Profile Views <span id="sort-ind-profileViews" class="opacity-40 group-hover:opacity-70">↕</span></span>
                  </th>
                  <th data-sort="likes"        class="px-4 py-3 text-left text-neutral-500 font-medium whitespace-nowrap cursor-pointer hover:text-neutral-300 select-none transition-colors group">
                    <span class="flex items-center gap-1">Likes <span id="sort-ind-likes" class="opacity-40 group-hover:opacity-70">↕</span></span>
                  </th>
                  <th data-sort="comments"     class="px-4 py-3 text-left text-neutral-500 font-medium whitespace-nowrap cursor-pointer hover:text-neutral-300 select-none transition-colors group">
                    <span class="flex items-center gap-1">Comments <span id="sort-ind-comments" class="opacity-40 group-hover:opacity-70">↕</span></span>
                  </th>
                  <th data-sort="shares"       class="px-4 py-3 text-left text-neutral-500 font-medium whitespace-nowrap cursor-pointer hover:text-neutral-300 select-none transition-colors group">
                    <span class="flex items-center gap-1">Shares <span id="sort-ind-shares" class="opacity-40 group-hover:opacity-70">↕</span></span>
                  </th>
                  <th id="delta-col-header" class="hidden px-4 py-3 text-left text-neutral-500 font-medium whitespace-nowrap">
                    Δ <span id="delta-col-label">Video Views</span>
                  </th>
                </tr>
              </thead>
              <tbody id="table-body"></tbody>
            </table>
          </div>
        </div>

      </div>
    </>
  ) : (
    <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-12 flex flex-col items-center gap-4 text-center">
      <div class="w-12 h-12 rounded-2xl bg-neutral-800 flex items-center justify-center text-2xl">↗</div>
      <div>
        <h2 class="text-sm font-semibold text-white mb-1">No data yet</h2>
        <p class="text-xs text-neutral-500">Import a CSV from TikTok Studio to see your analytics here.</p>
      </div>
      <a
        href="/admin/import/tiktok"
        class="mt-2 bg-white text-black text-sm font-semibold px-5 py-2.5 rounded-xl hover:bg-neutral-100 transition-colors"
      >
        Import CSV
      </a>
    </div>
  )}

</div>
</AdminLayout>

<script define:vars={{ chartData: daily }}>
const METRICS = [
  { key: "videoViews",   label: "Video Views",   color: "#818cf8" },
  { key: "profileViews", label: "Profile Views", color: "#34d399" },
  { key: "likes",        label: "Likes",         color: "#f472b6" },
  { key: "comments",     label: "Comments",      color: "#fb923c" },
  { key: "shares",       label: "Shares",        color: "#60a5fa" },
];

const allData = chartData; // full date-sorted array

// ── State ─────────────────────────────────────────────────────────────────────
let active      = METRICS[0];
let activeRange = "all";
let customFrom  = "";
let customTo    = "";
let filteredData = [...allData]; // after range filter — used by chart + stats
let sortCol     = "date";
let sortDir     = "desc";
let showDelta   = false;
let searchText  = "";
let filterMetric = "videoViews";
let filterMin   = "";

// ── Helpers ───────────────────────────────────────────────────────────────────
function fmtNum(n) {
  const abs = Math.abs(n);
  if (abs >= 1e6) return (n / 1e6).toFixed(1) + "M";
  if (abs >= 1e3) return (n / 1e3).toFixed(1) + "K";
  return n.toLocaleString();
}
function fmtAxisDate(iso) {
  const [, m, d] = iso.split("-").map(Number);
  const M = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
  return `${M[m-1]} ${d}`;
}
function fmtFullDate(iso) {
  const [y, m, d] = iso.split("-").map(Number);
  const M = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
  return `${M[m-1]} ${d}, ${y}`;
}

// ── Range filter ──────────────────────────────────────────────────────────────
function applyRange() {
  if (!allData.length) return [];
  if (activeRange === "custom") {
    const from = customFrom || allData[0].date;
    const to   = customTo   || allData[allData.length - 1].date;
    return allData.filter(d => d.date >= from && d.date <= to);
  }
  if (activeRange === "all") return [...allData];
  const days = { "7d": 7, "30d": 30, "90d": 90, "1y": 365 }[activeRange];
  const cutoff = new Date();
  cutoff.setDate(cutoff.getDate() - days);
  return allData.filter(d => d.date >= cutoff.toISOString().slice(0, 10));
}

// ── Build table rows: attach delta, then filter, then sort ────────────────────
function buildTableRows(data) {
  // Deltas are computed against date order before any sorting/filtering
  const withDelta = data.map((row, i) => {
    const prev = i > 0 ? data[i - 1][active.key] : null;
    return { ...row, _delta: prev !== null ? row[active.key] - prev : null };
  });

  let rows = withDelta;

  if (searchText) {
    const q = searchText.toLowerCase();
    rows = rows.filter(r => fmtFullDate(r.date).toLowerCase().includes(q));
  }

  if (filterMin !== "" && !isNaN(Number(filterMin))) {
    const min = Number(filterMin);
    rows = rows.filter(r => r[filterMetric] >= min);
  }

  rows = [...rows].sort((a, b) => {
    const av = sortCol === "date" ? a.date : a[sortCol];
    const bv = sortCol === "date" ? b.date : b[sortCol];
    if (av < bv) return sortDir === "asc" ? -1 : 1;
    if (av > bv) return sortDir === "asc" ?  1 : -1;
    return 0;
  });

  return rows;
}

// ── Summary cards ─────────────────────────────────────────────────────────────
function updateStats(data) {
  const totalViews = data.reduce((s, d) => s + d.videoViews, 0);
  const totalLikes = data.reduce((s, d) => s + d.likes, 0);
  const totalShares= data.reduce((s, d) => s + d.shares, 0);
  const avg        = data.length ? Math.round(totalViews / data.length) : 0;
  const peak       = data.length
    ? data.reduce((b, d) => d.videoViews > b.videoViews ? d : b, data[0])
    : null;

  document.getElementById("stat-video-views").textContent = fmtNum(totalViews);
  document.getElementById("stat-avg-views").textContent   = fmtNum(avg);
  document.getElementById("stat-likes").textContent       = fmtNum(totalLikes);
  document.getElementById("stat-shares").textContent      = fmtNum(totalShares);
  document.getElementById("stat-peak-date").textContent   = peak ? fmtFullDate(peak.date) : "—";
  document.getElementById("stat-peak-sub").textContent    = peak ? fmtNum(peak.videoViews) + " views" : "";
}

// ── Date range label ──────────────────────────────────────────────────────────
function updateLabel(data) {
  const el = document.getElementById("date-range-label");
  if (!el) return;
  if (!data.length) { el.textContent = "No data in this range"; return; }
  el.textContent = `${data.length} days · ${fmtFullDate(data[0].date)} – ${fmtFullDate(data[data.length - 1].date)}`;
}

// ── Sort indicators ───────────────────────────────────────────────────────────
const SORT_COLS = ["date","videoViews","profileViews","likes","comments","shares"];
function updateSortIndicators() {
  for (const col of SORT_COLS) {
    const el = document.getElementById(`sort-ind-${col}`);
    if (!el) continue;
    if (col === sortCol) {
      el.textContent = sortDir === "asc" ? "↑" : "↓";
      el.style.opacity = "1";
    } else {
      el.textContent = "↕";
      el.style.opacity = "";
    }
  }
}

// ── Table ─────────────────────────────────────────────────────────────────────
function updateTable(data) {
  const rows = buildTableRows(data);
  const tbody   = document.getElementById("table-body");
  const countEl = document.getElementById("table-row-count");
  if (!tbody) return;

  const filtered = (searchText || filterMin !== "") && rows.length !== data.length;
  countEl.textContent = filtered
    ? `${rows.length} of ${data.length} rows`
    : `${rows.length} rows`;

  tbody.innerHTML = rows.map(row => {
    const delta = row._delta;
    const deltaCell = showDelta
      ? `<td class="px-4 py-2.5 tabular-nums ${
          delta === null ? "text-neutral-600" :
          delta > 0      ? "text-emerald-400"  :
          delta < 0      ? "text-red-400"      : "text-neutral-500"
        }">
          ${delta === null ? "—" : (delta > 0 ? "+" : "") + fmtNum(delta)}
        </td>`
      : "";
    return `<tr class="border-b border-neutral-800/50 hover:bg-neutral-800/30 transition-colors">
      <td class="px-4 py-2.5 text-neutral-300 whitespace-nowrap font-mono">${fmtFullDate(row.date)}</td>
      <td class="px-4 py-2.5 text-white tabular-nums font-medium">${row.videoViews.toLocaleString()}</td>
      <td class="px-4 py-2.5 text-neutral-400 tabular-nums">${row.profileViews.toLocaleString()}</td>
      <td class="px-4 py-2.5 text-pink-400 tabular-nums">${row.likes.toLocaleString()}</td>
      <td class="px-4 py-2.5 text-neutral-400 tabular-nums">${row.comments.toLocaleString()}</td>
      <td class="px-4 py-2.5 text-sky-400 tabular-nums">${row.shares.toLocaleString()}</td>
      ${deltaCell}
    </tr>`;
  }).join("");
}

// ── Chart ─────────────────────────────────────────────────────────────────────
const canvas  = document.getElementById("chart");
const tooltip = document.getElementById("chart-tooltip");
const ctx     = canvas ? canvas.getContext("2d") : null;

function drawChart() {
  if (!canvas || !ctx) return;
  const data = filteredData;
  if (!data.length) return;

  const dpr  = window.devicePixelRatio || 1;
  const cssW = canvas.getBoundingClientRect().width;
  const cssH = 260;
  canvas.width  = cssW * dpr;
  canvas.height = cssH * dpr;
  ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

  const padL = 62, padR = 16, padT = 20, padB = 38;
  const cW = cssW - padL - padR;
  const cH = cssH - padT - padB;

  const values = data.map(d => d[active.key]);
  const maxV   = Math.max(...values, 1);
  const minV   = Math.min(0, ...values);
  const range  = maxV - minV || 1;

  ctx.clearRect(0, 0, cssW, cssH);
  ctx.font         = "10px system-ui, sans-serif";
  ctx.textBaseline = "middle";

  for (let i = 0; i <= 5; i++) {
    const y   = padT + cH - (i / 5) * cH;
    const val = minV + (i / 5) * range;
    ctx.strokeStyle = "rgba(255,255,255,0.06)";
    ctx.lineWidth   = 1;
    ctx.beginPath(); ctx.moveTo(padL, y); ctx.lineTo(padL + cW, y); ctx.stroke();
    ctx.fillStyle  = "rgba(255,255,255,0.35)";
    ctx.textAlign  = "right";
    ctx.fillText(fmtNum(val), padL - 6, y);
  }

  const labelEvery = Math.max(1, Math.floor(data.length / 7));
  ctx.textAlign    = "center";
  ctx.textBaseline = "top";
  ctx.fillStyle    = "rgba(255,255,255,0.3)";
  for (let i = 0; i < data.length; i += labelEvery) {
    const x = padL + (i / (data.length - 1 || 1)) * cW;
    ctx.fillText(fmtAxisDate(data[i].date), x, padT + cH + 8);
  }

  const grad = ctx.createLinearGradient(0, padT, 0, padT + cH);
  grad.addColorStop(0, active.color + "55");
  grad.addColorStop(1, active.color + "00");

  const points = data.map((d, i) => ({
    x: padL + (i / (data.length - 1 || 1)) * cW,
    y: padT + cH - ((d[active.key] - minV) / range) * cH,
  }));

  ctx.beginPath();
  points.forEach((p, i) => i === 0 ? ctx.moveTo(p.x, p.y) : ctx.lineTo(p.x, p.y));
  ctx.lineTo(points[points.length - 1].x, padT + cH);
  ctx.lineTo(points[0].x, padT + cH);
  ctx.closePath();
  ctx.fillStyle = grad;
  ctx.fill();

  ctx.beginPath();
  points.forEach((p, i) => i === 0 ? ctx.moveTo(p.x, p.y) : ctx.lineTo(p.x, p.y));
  ctx.strokeStyle = active.color;
  ctx.lineWidth   = 2;
  ctx.lineJoin    = "round";
  ctx.stroke();
}

// ── Tooltip ───────────────────────────────────────────────────────────────────
if (canvas && tooltip) {
  canvas.addEventListener("mousemove", (e) => {
    const data = filteredData;
    if (!data.length) return;
    const rect = canvas.getBoundingClientRect();
    const cW   = rect.width - 62 - 16;
    const xRel = e.clientX - rect.left;
    const idx  = Math.round(((xRel - 62) / cW) * (data.length - 1));
    if (idx < 0 || idx >= data.length) { tooltip.style.display = "none"; return; }

    const d    = data[idx];
    const val  = d[active.key];
    const left = Math.min(xRel, rect.width - 138);
    const top  = Math.max(0, e.clientY - rect.top - 68);

    tooltip.style.cssText = `display:block;left:${left}px;top:${top}px`;
    tooltip.innerHTML =
      `<div class="text-neutral-400 mb-0.5">${fmtFullDate(d.date)}</div>` +
      `<div class="text-white font-semibold">${fmtNum(val)}</div>` +
      `<div class="text-neutral-500">${active.label}</div>`;
  });
  canvas.addEventListener("mouseleave", () => { tooltip.style.display = "none"; });
}

// ── Export CSV ────────────────────────────────────────────────────────────────
function exportCsv() {
  const rows = buildTableRows(filteredData);
  const headers = ["Date","Video Views","Profile Views","Likes","Comments","Shares"];
  if (showDelta) headers.push(`Δ ${active.label}`);

  const lines = [
    headers.join(","),
    ...rows.map(r => {
      const cells = [
        r.date,
        r.videoViews,
        r.profileViews,
        r.likes,
        r.comments,
        r.shares,
      ];
      if (showDelta) cells.push(r._delta ?? "");
      return cells.join(",");
    }),
  ];

  const blob = new Blob([lines.join("\n")], { type: "text/csv" });
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement("a");
  a.href     = url;
  a.download = `tiktok-analytics-${activeRange}.csv`;
  a.click();
  URL.revokeObjectURL(url);
}

// ── Full render ───────────────────────────────────────────────────────────────
function render() {
  filteredData = applyRange();
  updateStats(filteredData);
  updateLabel(filteredData);
  updateSortIndicators();
  updateTable(filteredData);
  drawChart();
}

// ── Range buttons ─────────────────────────────────────────────────────────────
document.querySelectorAll("[data-range]").forEach(btn => {
  btn.addEventListener("click", () => {
    activeRange = btn.dataset.range;

    document.querySelectorAll("[data-range]").forEach(b => {
      b.classList.remove("bg-neutral-800", "text-white");
      b.classList.add("text-neutral-500", "hover:text-neutral-300");
    });
    btn.classList.add("bg-neutral-800", "text-white");
    btn.classList.remove("text-neutral-500", "hover:text-neutral-300");

    const customEl = document.getElementById("custom-range");
    if (customEl) {
      customEl.classList.toggle("hidden", activeRange !== "custom");
      customEl.classList.toggle("flex",   activeRange === "custom");
    }

    render();
  });
});

// ── Custom date inputs ────────────────────────────────────────────────────────
const fromInput = document.getElementById("custom-from");
const toInput   = document.getElementById("custom-to");

fromInput?.addEventListener("change", () => {
  customFrom = fromInput.value;
  if (activeRange === "custom") render();
});
toInput?.addEventListener("change", () => {
  customTo = toInput.value;
  if (activeRange === "custom") render();
});

// ── Sort column headers ───────────────────────────────────────────────────────
document.querySelectorAll("th[data-sort]").forEach(th => {
  th.addEventListener("click", () => {
    const col = th.dataset.sort;
    if (sortCol === col) {
      sortDir = sortDir === "asc" ? "desc" : "asc";
    } else {
      sortCol = col;
      sortDir = col === "date" ? "desc" : "desc";
    }
    updateSortIndicators();
    updateTable(filteredData);
  });
});

// ── Metric buttons ────────────────────────────────────────────────────────────
document.querySelectorAll("[data-metric]").forEach(btn => {
  btn.addEventListener("click", () => {
    active = METRICS.find(m => m.key === btn.dataset.metric) || METRICS[0];
    document.querySelectorAll("[data-metric]").forEach(b => {
      b.classList.remove("bg-neutral-800", "text-white");
      b.classList.add("text-neutral-500");
    });
    btn.classList.add("bg-neutral-800", "text-white");
    btn.classList.remove("text-neutral-500");

    // Update delta column label if visible
    const lbl = document.getElementById("delta-col-label");
    if (lbl) lbl.textContent = active.label;

    updateTable(filteredData);
    drawChart();
  });
});

// ── Delta toggle ──────────────────────────────────────────────────────────────
document.getElementById("delta-toggle")?.addEventListener("click", (e) => {
  showDelta = !showDelta;
  const btn = e.currentTarget;
  btn.classList.toggle("text-white",       showDelta);
  btn.classList.toggle("border-neutral-600", showDelta);
  btn.classList.toggle("text-neutral-500",  !showDelta);
  btn.classList.toggle("border-neutral-800",!showDelta);

  const header = document.getElementById("delta-col-header");
  header?.classList.toggle("hidden", !showDelta);

  updateTable(filteredData);
});

// ── Export ────────────────────────────────────────────────────────────────────
document.getElementById("export-csv")?.addEventListener("click", exportCsv);

// ── Search ────────────────────────────────────────────────────────────────────
document.getElementById("search-date")?.addEventListener("input", (e) => {
  searchText = e.target.value.trim();
  updateTable(filteredData);
});

// ── Min-value filter ──────────────────────────────────────────────────────────
document.getElementById("filter-metric")?.addEventListener("change", (e) => {
  filterMetric = e.target.value;
  updateTable(filteredData);
});
document.getElementById("filter-min")?.addEventListener("input", (e) => {
  filterMin = e.target.value;
  updateTable(filteredData);
});

// ── Clear filters ─────────────────────────────────────────────────────────────
document.getElementById("clear-filters")?.addEventListener("click", () => {
  searchText  = "";
  filterMin   = "";
  filterMetric = "videoViews";
  const searchEl  = document.getElementById("search-date");
  const minEl     = document.getElementById("filter-min");
  const metricSel = document.getElementById("filter-metric");
  if (searchEl)  searchEl.value  = "";
  if (minEl)     minEl.value     = "";
  if (metricSel) metricSel.value = "videoViews";
  updateTable(filteredData);
});

// ── Init ──────────────────────────────────────────────────────────────────────
window.addEventListener("load",   render);
window.addEventListener("resize", drawChart);
</script>
