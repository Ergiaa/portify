---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { db } from "@portify/db";
import { platforms } from "@portify/db/schema/platforms";

const connectedPlatforms = await db.select({
  name: platforms.name,
  accountName: platforms.accountName,
  accountId: platforms.accountId,
  lastSyncedAt: platforms.lastSyncedAt,
  lastSyncStatus: platforms.lastSyncStatus,
  lastSyncError: platforms.lastSyncError,
  connectedAt: platforms.connectedAt,
  syncEnabled: platforms.syncEnabled,
}).from(platforms);

const connectedMap = Object.fromEntries(connectedPlatforms.map((p) => [p.name, p]));

const supported = [
  { name: "tiktok", label: "TikTok" },
  { name: "instagram", label: "Instagram" },
] as const;

const connected = Astro.url.searchParams.get("connected");
---

<AdminLayout title="Platforms">
<div class="px-8 py-10" style="max-width:760px;">

  <!-- Header -->
  <div class="mb-7">
    <h1 class="font-bold" style="font-size:21px;color:var(--text-1);">Platforms</h1>
    <p class="text-sm mt-1" style="color:var(--text-2);">Connect your social accounts to sync content statistics automatically.</p>
  </div>

  <!-- Success banner -->
  {connected && (
    <div class="mb-5 px-4 py-3 text-sm" style="background:var(--green-muted);border:1px solid oklch(70% 0.17 145 / 0.2);border-radius:var(--r-sm);color:var(--green);">
      Platform connected successfully.
    </div>
  )}

  {Astro.url.searchParams.get("error") && (
    <div class="mb-5 px-4 py-3 text-sm" style="background:var(--red-muted);border:1px solid oklch(65% 0.2 25 / 0.2);border-radius:var(--r-sm);color:var(--red);">
      {{
        access_denied: "You denied access to the platform.",
        invalid_state: "Security check failed. Please try again.",
        invalid_callback: "Invalid callback. Please try again.",
        callback_failed: "Connection failed — check server logs.",
        not_configured: "Platform credentials are not configured on the server.",
      }[Astro.url.searchParams.get("error")!] ?? "Connection failed. Please try again."}
    </div>
  )}

  <div id="status-msg" class="hidden mb-5 px-4 py-3 text-sm" style="border-radius:var(--r-sm);"></div>

  <!-- Platform cards -->
  <div class="flex flex-col gap-3">
    {supported.map(({ name, label }) => {
      const platform = connectedMap[name];
      const isConnected = !!platform;
      const hasError = platform?.lastSyncStatus === "error";
      const isSyncing = platform?.lastSyncStatus === "in_progress";

      return (
        <div class="p-5" style="background:var(--surface-2);border:1px solid var(--border);border-radius:var(--r-md);" data-platform={name}>
          <div class="flex items-start justify-between gap-4">
            <!-- Left -->
            <div class="flex items-center gap-4">
              <!-- Icon placeholder -->
              <div class="flex items-center justify-center" style="width:44px;height:44px;border-radius:var(--r-md);background:var(--surface-3);border:1px solid var(--border);flex-shrink:0;">
                {name === "tiktok" ? (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="color:var(--text-2);">
                    <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.95a8.16 8.16 0 004.77 1.52V7.02a4.85 4.85 0 01-1-.33z"/>
                  </svg>
                ) : (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color:var(--text-2);">
                    <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
                  </svg>
                )}
              </div>

              <div>
                <div class="flex items-center gap-2.5 mb-0.5">
                  <span class="text-sm font-semibold" style="color:var(--text-1);">{label}</span>
                  {isConnected ? (
                    <span
                      class="forge-badge"
                      style={hasError
                        ? "background:var(--red-muted);color:var(--red);"
                        : "background:var(--green-muted);color:var(--green);"}
                    >
                      <span class="forge-badge-dot" style={hasError ? "background:var(--red);" : "background:var(--green);"}></span>
                      {hasError ? "Error" : "Connected"}
                    </span>
                  ) : (
                    <span class="forge-badge" style="background:var(--surface-3);color:var(--text-3);">
                      <span class="forge-badge-dot" style="background:var(--text-3);"></span>
                      Not connected
                    </span>
                  )}
                </div>
                {isConnected && platform.accountName ? (
                  <p class="text-xs" style="color:var(--text-2);">
                    @{platform.accountName}
                    {platform.lastSyncedAt && (
                      <> &bull; Last synced {platform.lastSyncedAt.toLocaleDateString("en-US", { month: "short", day: "numeric", hour: "2-digit", minute: "2-digit" })}</>
                    )}
                  </p>
                ) : !isConnected ? (
                  <p class="text-xs" style="color:var(--text-3);">No account linked</p>
                ) : null}
                {hasError && platform.lastSyncError && (
                  <p class="mt-1 text-xs" style="color:var(--red);">{platform.lastSyncError}</p>
                )}
              </div>
            </div>

            <!-- Right: actions -->
            <div class="flex items-center gap-2 shrink-0">
              {isConnected ? (
                <>
                  <button
                    data-sync-btn={name}
                    disabled={isSyncing}
                    class="forge-btn forge-btn-secondary"
                    style="font-size:12px;padding:0.3rem 0.75rem;"
                  >
                    {isSyncing ? "Syncing…" : "Sync now"}
                  </button>
                  <button
                    data-disconnect-btn={name}
                    class="forge-btn forge-btn-danger"
                    style="font-size:12px;padding:0.3rem 0.75rem;"
                  >
                    Disconnect
                  </button>
                </>
              ) : (
                <button
                  data-connect-btn={name}
                  class="forge-btn forge-btn-primary"
                  style="font-size:12px;padding:0.3rem 0.75rem;"
                >
                  Connect
                </button>
              )}
            </div>
          </div>
        </div>
      );
    })}
  </div>

  <p class="mt-5 text-xs" style="color:var(--text-3);">
    Statistics are synced every 6 hours. Connected accounts must be Professional (Instagram) or linked to an approved developer app (TikTok).
  </p>

</div>
</AdminLayout>

<script>
  import { adminOrpc } from "../../../lib/admin-orpc";
  import { PUBLIC_SERVER_URL } from "astro:env/client";

  function showMsg(text: string, type: "success" | "error") {
    const el = document.getElementById("status-msg")!;
    el.textContent = text;
    if (type === "success") {
      el.style.cssText = "background:var(--green-muted);border:1px solid oklch(70% 0.17 145 / 0.2);border-radius:var(--r-sm);color:var(--green);";
    } else {
      el.style.cssText = "background:var(--red-muted);border:1px solid oklch(65% 0.2 25 / 0.2);border-radius:var(--r-sm);color:var(--red);";
    }
    el.classList.remove("hidden");
    el.classList.add("mb-5", "px-4", "py-3", "text-sm");
    setTimeout(() => el.classList.add("hidden"), 4000);
  }

  document.querySelectorAll("[data-connect-btn]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const name = (btn as HTMLElement).dataset.connectBtn!;
      (btn as HTMLButtonElement).disabled = true;
      (btn as HTMLButtonElement).textContent = "Redirecting…";
      try {
        const res = await fetch(`${PUBLIC_SERVER_URL}/api/platforms/${name}/connect`, {
          headers: { Authorization: `Bearer ${document.cookie.split("; ").find(c => c.startsWith("auth_token="))?.split("=")[1] ?? ""}` },
        });
        if (!res.ok) throw new Error("OAuth not configured yet");
        const { url } = await res.json();
        window.location.href = url;
      } catch (e: any) {
        showMsg(e.message ?? "Failed to initiate connection", "error");
        (btn as HTMLButtonElement).disabled = false;
        (btn as HTMLButtonElement).textContent = "Connect";
      }
    });
  });

  document.querySelectorAll("[data-sync-btn]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const name = (btn as HTMLElement).dataset.syncBtn! as "tiktok" | "instagram" | "youtube";
      (btn as HTMLButtonElement).disabled = true;
      (btn as HTMLButtonElement).textContent = "Syncing…";
      try {
        await adminOrpc.platforms.triggerSync({ name });
        showMsg("Sync queued successfully", "success");
      } catch {
        showMsg("Failed to trigger sync", "error");
      } finally {
        (btn as HTMLButtonElement).disabled = false;
        (btn as HTMLButtonElement).textContent = "Sync now";
      }
    });
  });

  document.querySelectorAll("[data-disconnect-btn]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const name = (btn as HTMLElement).dataset.disconnectBtn! as "tiktok" | "instagram" | "youtube";
      if (!confirm(`Disconnect ${name}? This will stop stats syncing.`)) return;

      (btn as HTMLButtonElement).disabled = true;
      (btn as HTMLButtonElement).textContent = "…";
      try {
        await adminOrpc.platforms.disconnect({ name });
        window.location.reload();
      } catch {
        showMsg("Failed to disconnect platform", "error");
        (btn as HTMLButtonElement).disabled = false;
        (btn as HTMLButtonElement).textContent = "Disconnect";
      }
    });
  });
</script>
