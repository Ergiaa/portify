---
import { db } from "@portify/db";
import { contentItems } from "@portify/db/schema/content";
import { platformMetrics } from "@portify/db/schema/metrics";
import { eq, desc } from "drizzle-orm";
import Layout from "../layouts/Layout.astro";
import ContentGrid from "../components/ContentGrid.astro";

const items = await db
  .select({
    id: contentItems.id,
    title: contentItems.title,
    description: contentItems.description,
    type: contentItems.type,
    platform: contentItems.platform,
    thumbnailUrl: contentItems.thumbnailUrl,
    externalUrl: contentItems.externalUrl,
    publishedAt: contentItems.publishedAt,
  })
  .from(contentItems)
  .where(eq(contentItems.status, "published"))
  .orderBy(desc(contentItems.publishedAt));

const latestMetrics = await db
  .selectDistinctOn([platformMetrics.contentItemId], {
    contentItemId: platformMetrics.contentItemId,
    views: platformMetrics.views,
    likes: platformMetrics.likes,
    shares: platformMetrics.shares,
  })
  .from(platformMetrics)
  .orderBy(platformMetrics.contentItemId, desc(platformMetrics.fetchedAt));

const metricsMap = new Map(latestMetrics.map(m => [m.contentItemId, m]));

const itemsWithMetrics = items.map(item => ({
  ...item,
  metrics: metricsMap.get(item.id) ?? null,
}));
---

<Layout title="Film Reviews">
  <main class="max-w-5xl mx-auto px-4 sm:px-6 py-16 sm:py-20">

    <!-- Page header -->
    <div class="mb-12 pb-12 border-b border-neutral-800">
      <p class="text-xs font-semibold tracking-widest uppercase text-indigo-400 mb-4">
        Portfolio
      </p>
      <h1 class="text-4xl sm:text-5xl font-bold text-white tracking-tight leading-tight mb-4">
        Film Reviews
      </h1>
      <p class="text-neutral-400 text-lg leading-relaxed max-w-xl">
        Every film is an argument. Here are mine.
      </p>
      <p class="text-neutral-600 text-sm mt-4">
        {items.length === 1 ? "1 piece" : `${items.length} pieces`}
      </p>
    </div>

    <ContentGrid items={itemsWithMetrics} />
  </main>
</Layout>
